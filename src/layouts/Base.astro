---
import '../styles/global.css';

export interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  ogType?: string;
  publishedAt?: Date;
  noIndex?: boolean;
  personSchema?: boolean;
}

const {
  title,
  description = 'Christian Kameir — investor, writer, and lecturer based in Newport Beach, CA.',
  ogImage = '/images/og-default.jpg',
  ogType = 'website',
  publishedAt,
  noIndex = false,
  personSchema = false,
} = Astro.props;

// Strip .html from canonical URLs (clean URLs served via .htaccess rewrite)
const cleanPath = Astro.url.pathname.replace(/\.html$/, '');
const canonicalURL = new URL(cleanPath, Astro.site);
const fullTitle = title === 'Christian Kameir' ? title : `${title} — Christian Kameir`;
const ogImageAbsolute = new URL(ogImage, Astro.site);

const navLinks = [
  { href: '/about', label: 'About' },
  { href: '/writing', label: 'Writing' },
  { href: '/speaking', label: 'Speaking' },
  { href: '/contact', label: 'Contact' },
];

const personJsonLd = {
  "@context": "https://schema.org",
  "@type": "Person",
  "name": "Christian Kameir",
  "url": "https://kameir.com",
  "image": "https://kameir.com/images/christian-kameir.jpg",
  "description": "Independent advisory helping capital-intensive companies from German-speaking countries enter the US market, capture federal and state incentives, and connect with private capital.",
  "jobTitle": "Independent Advisor",
  "worksFor": {
    "@type": "Organization",
    "name": "Decentralized Publishing LLC"
  },
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Newport Beach",
    "addressRegion": "CA",
    "addressCountry": "US"
  },
  "alumniOf": [
    { "@type": "CollegeOrUniversity", "name": "University of Münster" },
    { "@type": "CollegeOrUniversity", "name": "University of Oxford" },
    { "@type": "CollegeOrUniversity", "name": "University of Bielefeld" },
    { "@type": "CollegeOrUniversity", "name": "University of Munich" }
  ],
  "knowsLanguage": [
    { "@type": "Language", "name": "English" },
    { "@type": "Language", "name": "German" }
  ],
  "sameAs": [
    "https://www.linkedin.com/in/kameir/",
    "https://x.com/kameir",
    "https://hackernoon.com/u/kameir",
    "https://www.forbes.com/councils/forbesfinancecouncil/people/christiankameir1/"
  ]
};
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="generator" content={Astro.generator} />

  <title>{fullTitle}</title>
  <meta name="description" content={description} />
  <meta name="author" content="Christian Kameir" />
  {noIndex
    ? <meta name="robots" content="noindex, nofollow" />
    : <meta name="robots" content="index, follow, max-image-preview:large" />
  }

  <link rel="canonical" href={canonicalURL} />

  <!-- Open Graph -->
  <meta property="og:type" content={ogType} />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:title" content={fullTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={ogImageAbsolute} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:site_name" content="Christian Kameir" />
  <meta property="og:locale" content="en_US" />
  {ogType === 'article' && publishedAt && (
    <>
      <meta property="article:published_time" content={publishedAt.toISOString()} />
      <meta property="article:author" content="https://kameir.com/about" />
      <meta property="article:section" content="Investing" />
    </>
  )}

  <!-- Twitter / X Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:site" content="@kameir" />
  <meta name="twitter:creator" content="@kameir" />
  <meta name="twitter:title" content={fullTitle} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImageAbsolute} />

  <!-- Favicon -->
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />

  <!-- Sitemap -->
  <link rel="sitemap" href="/sitemap-index.xml" />

  <!-- Preconnect for analytics -->
  <link rel="preconnect" href="https://plausible.io" />

  <!-- Plausible Analytics -->
  <script
    defer
    data-domain="kameir.com"
    src="https://plausible.io/js/script.js"
  ></script>

  <!-- Structured Data: Person (home + about pages) -->
  {personSchema && (
    <script type="application/ld+json" set:html={JSON.stringify(personJsonLd)} />
  )}

  <!-- Page-level structured data slot (e.g. Article schema on writing posts) -->
  <slot name="head" />
</head>

<body>
  <header>
    <nav class="site-nav" aria-label="Main navigation">
      <div class="site-nav__inner">
        <a href="/" class="site-nav__home">KAMEIR</a>
        <ul class="site-nav__links" role="list">
          {navLinks.map(({ href, label }) => (
            <li>
              <a
                href={href}
                aria-current={Astro.url.pathname === href || Astro.url.pathname.startsWith(href + '/') ? 'page' : undefined}
              >
                {label}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </nav>
  </header>

  <main id="main-content">
    <slot />
  </main>

  <footer class="site-footer">
    <div class="site-footer__inner">
      <span>© {new Date().getFullYear()} Decentralized Publishing LLC</span>
      <div class="site-footer__social">
        <a href="https://www.linkedin.com/in/kameir/" target="_blank" rel="noopener" aria-label="LinkedIn">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0