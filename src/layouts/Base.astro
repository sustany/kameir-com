---
import '../styles/global.css';

export interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  noIndex?: boolean;
}

const {
  title,
  description = 'Christian Kameir — investor, writer, and lecturer based in Newport Beach, CA.',
  ogImage = '/images/og-default.jpg',
  noIndex = false,
} = Astro.props;

// Strip .html from canonical URLs (clean URLs served via .htaccess rewrite)
const cleanPath = Astro.url.pathname.replace(/\.html$/, '');
const canonicalURL = new URL(cleanPath, Astro.site);
const fullTitle = title === 'Christian Kameir' ? title : `${title} — Christian Kameir`;

const navLinks = [
  { href: '/about', label: 'About' },
  { href: '/writing', label: 'Writing' },
  { href: '/speaking', label: 'Speaking' },
  { href: '/contact', label: 'Contact' },
];
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="generator" content={Astro.generator} />

  <title>{fullTitle}</title>
  <meta name="description" content={description} />
  {noIndex && <meta name="robots" content="noindex" />}

  <link rel="canonical" href={canonicalURL} />

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:title" content={fullTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={new URL(ogImage, Astro.site)} />
  <meta property="og:site_name" content="Christian Kameir" />

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={fullTitle} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={new URL(ogImage, Astro.site)} />

  <!-- Favicon -->
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

  <!-- Sitemap -->
  <link rel="sitemap" href="/sitemap-index.xml" />

  <!-- Plausible Analytics — replace 'kameir.com' if your Plausible domain differs -->
  <script
    defer
    data-domain="kameir.com"
    src="https://plausible.io/js/script.js"
  ></script>
</head>

<body>
  <header>
    <nav class="site-nav" aria-label="Main navigation">
      <div class="site-nav__inner">
        <a href="/" class="site-nav__home">Christian Kameir</a>
        <ul class="site-nav__links" role="list">
          {navLinks.map(({ href, label }) => (
            <li>
              <a
                href={href}
                aria-current={Astro.url.pathname === href || Astro.url.pathname.startsWith(href + '/') ? 'page' : undefined}
              >
                {label}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </nav>
  </header>

  <main id="main-content">
    <slot />
  </main>

  <footer class="site-footer">
    <div class="site-footer__inner">
      <span>© {new Date().getFullYear()} Decentralized Publishing LLC</span>
      <div class="site-footer__social">
        <a href="https://www.linkedin.com/in/kameir/" target="_blank" rel="noopener" aria-label="LinkedIn">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
          </svg>
        </a>
        <a href="https://x.com/kameir" target="_blank" rel="noopener" aria-label="X (Twitter)">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.746l7.73-8.835L1.254 2.25H8.08l4.253 5.622zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
          </svg>
        </a>
        <!-- HackerNoon: filled rounded-square badge, H as negative-space cutout -->
        <a href="https://hackernoon.com/u/kameir" target="_blank" rel="noopener" aria-label="HackerNoon">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path fill-rule="evenodd" d="M4 2h16a2 2 0 0 1 2 2v16a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2zM6 6h2.5v5h7V6H18v12h-2.5v-5h-7v5H6V6z"/>
          </svg>
        </a>
        <!-- Forbes: filled rounded-square badge, F as negative-space cutout -->
        <a href="https://www.forbes.com/councils/forbesfinancecouncil/people/christiankameir1/" target="_blank" rel="noopener" aria-label="Forbes">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path fill-rule="evenodd" d="M4 2h16a2 2 0 0 1 2 2v16a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2zM5 5h14v3H8v3h8v3H8v5H5V5z"/>
          </svg>
        </a>
        <a href="/contact" class="site-footer__contact">Get in touch</a>
      </div>
    </div>
  </footer>
</body>
</html>
