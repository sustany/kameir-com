---
import Base from '../layouts/Base.astro';

const speakingJsonLd = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Christian Kameir — Speaking",
  "description": "Keynotes on the future of money, blockchain investing, decentralized finance, and digital identity. Practitioner-level sessions for conferences and executive events.",
  "url": "https://kameir.com/speaking",
  "provider": {
    "@type": "Person",
    "name": "Christian Kameir",
    "url": "https://kameir.com",
    "jobTitle": "Keynote Speaker & Independent Advisor",
    "sameAs": [
      "https://www.linkedin.com/in/kameir/",
      "https://x.com/kameir"
    ]
  },
  "serviceType": "Public Speaking",
  "areaServed": "Worldwide",
  "offers": {
    "@type": "Offer",
    "priceSpecification": {
      "@type": "PriceSpecification",
      "priceCurrency": "USD",
      "minPrice": 1950,
      "description": "Virtual keynote from $1,950"
    }
  }
};
---

<Base
  title="Speaking"
  description="Keynotes on the future of money, blockchain investing, and decentralized finance. Practitioner-level conference sessions and expert panels for executive audiences. From $1,950."
>
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(speakingJsonLd)} />