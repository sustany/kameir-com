---
import Base from '../../../layouts/Base.astro';

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "US Site Selection Advisory for German Manufacturers",
  "description": "Independent site selection advisory for German manufacturers entering the US market. Evaluates states, counties, and incentive packages without referral fees from location promoters. Bilingual German/English.",
  "provider": {
    "@type": "Person",
    "name": "Christian Kameir",
    "url": "https://kameir.com"
  },
  "areaServed": { "@type": "Country", "name": "United States" },
  "serviceType": "Industrial Site Selection Consulting",
  "inLanguage": ["en", "de"],
  "url": "https://kameir.com/advisory/us-site-selection-german-manufacturers"
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://kameir.com" },
    { "@type": "ListItem", "position": 2, "name": "Advisory", "item": "https://kameir.com/advisory" },
    { "@type": "ListItem", "position": 3, "name": "German Companies — US Market Entry", "item": "https://kameir.com/advisory/german-companies-us-market-entry" },
    { "@type": "ListItem", "position": 4, "name": "US Site Selection", "item": "https://kameir.com/advisory/us-site-selection-german-manufacturers" }
  ]
};
---

<Base
  title="US Site Selection for German Manufacturers — Advisory | Christian Kameir"
  description="Independent site selection for German manufacturers entering the US. Evaluates states, workforce, and incentive packages with no referral fees from location promoters. Bilingual German/English. Newport Beach, CA."
  canonicalUrl="https://kameir.com/advisory/us-site-selection-german-manufacturers"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  </Fragment>

  <article class="advisory">

    <section class="advisory__hero">
      <div class="container">
        <nav class="ss-breadcrumb">
          <a href="/advisory">Advisory</a>
          <span>›</span>
          <a href="/advisory/german-companies-us-market-entry">US Market Entry</a>
          <span>›</span>
          <span>Site Selection</span>
        </nav>

        <div class="ss-hero__text">
          <p class="label">US Site Selection · German Manufacturers</p>
          <h1 class="ss-hero__h1">How to Choose a US Location<br>Without Being Sold One</h1>
          <p class="ss-hero__lead">
            Every US state and most counties have an economic development agency whose explicit job is to attract companies like yours. Their materials are marketing. Their incentive projections are optimistic. Their workforce numbers reflect best-case assumptions. This practice evaluates locations the way an operator would — not the way a promoter would.
          </p>
          <div class="advisory__cta" style="margin-top: 2rem;">
            <a href="/contact" class="btn btn--primary">Discuss your site search</a>
            <a href="/advisory/german-companies-us-market-entry" class="btn btn--outline">Full market entry scope →</a>
          </div>
        </div>
      </div>
    </section>

    <div class="container"><hr class="rule" /></div>

    <!-- The conflict of interest problem -->
    <section class="ss-section">
      <div class="container">
        <h2 class="ss-section__h2">The Conflict at the Center of Site Selection</h2>
        <div class="ss-prose">
          <p>
            Most site selection consultants in the United States are compensated by the states and counties that win the client's business. The fee comes from the location that is chosen, not from the company doing the choosing. This creates a structural incentive to select whichever location is willing to pay the largest finder's fee — not necessarily the location that is best for the client.
          </p>
          <p>
            This practice does not accept referral fees from states, counties, or site-selection intermediaries. The engagement fee comes from the client. The analysis is done for the client.
          </p>
          <p>
            That distinction matters most when the right answer is to wait, to select a location that offered no fee, or to reject all candidates and repeat the search in a different region.
          </p>
        </div>
      </div>
    </section>

    <div class="container"><hr class="rule" /></div>

    <!-- What the evaluation covers -->
    <section class="ss-section">
      <div class="container">
        <p class="label">Evaluation framework</p>
        <div class="ss-criteria__grid">
          <div class="ss-criteria__item">
            <h3>Workforce Reality</h3>
            <p>State promotional materials cite metro-area labor statistics that rarely reflect conditions at a specific site. The evaluation maps actual commute sheds, unionization rates, competing employers within recruitment range, and the skilled trades availability for your specific manufacturing process.</p>
          </div>
          <div class="ss-criteria__item">
            <h3>Infrastructure & Utilities</h3>
            <p>Power availability, natural gas access, water rights, rail connectivity, and port access — assessed against your actual production requirements, not against general availability claims. Grid reliability is evaluated at the county level, not the regional level.</p>
          </div>
          <div class="ss-criteria__item">
            <h3>Incentive Package Analysis</h3>
            <p>State and county incentives are frequently structured with clawback provisions, employment minimums, and capital expenditure milestones that create significant compliance obligations. The evaluation models the net present value of each package against realistic production ramp scenarios, not the headline number.</p>
          </div>
          <div class="ss-criteria__item">
            <h3>Regulatory Environment</h3>
            <p>Environmental permitting timelines vary by two to four years between states for comparable projects. Some states have permitting pathways specifically designed for German-style industrial facilities under bilateral trade agreements. Others do not. The evaluation maps the realistic timeline for your project, not the statutory maximum.</p>
          </div>
          <div class="ss-criteria__item">
            <h3>Federal Incentive Layering</h3>
            <p>IRA tax credits, CHIPS Act grants, and DOE loan programs interact with state incentive packages in ways that create both optimization opportunities and compliance conflicts. The evaluation identifies the layering strategy that maximizes net benefit without creating reporting conflicts.</p>
          </div>
          <div class="ss-criteria__item">
            <h3>Political Risk</h3>
            <p>Incentive packages negotiated with one administration are sometimes reversed by the next. The evaluation assesses the political durability of each package — including which provisions are legally binding versus which depend on executive goodwill.</p>
          </div>
        </div>
      </div>
    </section>

    <div class="container"><hr class="rule" /></div>

    <!-- Process -->
    <section class="ss-section">
      <div class="container">
        <p class="label">How the site search works</p>
        <ol class="ss-process__list">
          <li>
            <strong>Requirement Mapping</strong>
            <span>Before any location is evaluated, the practice maps the non-negotiable requirements for your specific manufacturing process — power, water, rail, workforce, permitting, capital structure — and ranks them by weight. The ranking becomes the filter that eliminates candidates before the list is presented to state agencies.</span>
          </li>
          <li>
            <strong>Long-list Development</strong>
            <span>Using the requirement filter, the practice develops a long list of candidate states — typically four to eight — without soliciting proposals from economic development agencies. This prevents the negotiating position from being compromised before the conversation begins.</span>
          </li>
          <li>
            <strong>Parallel Incentive Negotiation</strong>
            <span>Proposals are solicited simultaneously from all candidate states and counties. This creates genuine competition among locations and prevents any single jurisdiction from assuming the decision is already made.</span>
          </li>
          <li>
            <strong>Independent Verification</strong>
            <span>All workforce, infrastructure, and incentive claims are verified against primary sources — utility interconnection agreements, county assessor records, actual permitting timelines for comparable projects — before being included in the comparative analysis delivered to the client.</span>
          </li>
          <li>
            <strong>Decision Support</strong>
            <span>The final deliverable is a written comparative analysis — in English and German — that presents the verified characteristics of each finalist location, the modeled net present value of each incentive package, and a recommendation with explicit assumptions and risk factors.</span>
          </li>
        </ol>
      </div>
    </section>

    <div class="container"><hr class="rule" /></div>

    <section class="ss-section">
      <div class="container ss-related">
        <p class="label">Related</p>
        <div class="ss-related__links">
          <a href="/advisory/ira-incentives-german-companies" class="gme-subpage__card">
            <span class="gme-subpage__label">Federal Incentives</span>
            <h3>IRA Incentives for German Companies</h3>
            <p>The tax credits and grants available to German manufacturers under the Inflation Reduction Act — and the structuring decisions that determine eligibility.</p>
            <span class="gme-subpage__link">Read more →</span>
          </a>
          <a href="/advisory/german-companies-us-market-entry" class="gme-subpage__card">
            <span class="gme-subpage__label">Full Scope</span>
            <h3>US Market Entry for German Companies</h3>
            <p>Site selection is one part of the entry arc. See the full engagement scope — market assessment, capital sourcing, and corporate structuring.</p>
            <span class="gme-subpage__link">Read more →</span>
          </a>
        </div>
        <div style="margin-top: 2.5rem;">
          <a href="/contact" class="btn btn--primary">Discuss your site search</a>
        </div>
      </div>
    </section>

  </article>
</Base>

<style>
.advisory__hero { padding-top: 4rem; padding-bottom: var(--space-xl); padding-inline: var(--space-m); }
.advisory__cta { display: flex; gap: 1rem; flex-wrap: wrap; }
.ss-breadcrumb { display: flex; gap: 0.5rem; align-items: center; font-size: 0.82rem; color: var(--text-muted); margin-bottom: 2rem; }
.ss-breadcrumb a { color: var(--text-muted); text-decoration: none; }
.ss-breadcrumb a:hover { color: var(--accent, #1B3A5C); }
.ss-hero__h1 { font-family: var(--font-display); font-size: clamp(1.9rem, 4.5vw, 3rem); font-weight: 700; line-height: 1.15; letter-spacing: -0.02em; color: var(--text); margin: 1rem 0 1.25rem; }
.ss-hero__lead { font-size: 1.05rem; line-height: 1.75; color: var(--text-muted); max-width: 620px; }
.ss-section { padding: var(--space-xl) var(--space-m); }
.ss-section .label { margin-bottom: 1.75rem; }
.ss-section__h2 { font-family: var(--font-display); font-size: clamp(1.4rem, 3vw, 2rem); color: var(--text); margin: 0 0 1.5rem; }
.ss-prose { max-width: 680px; }
.ss-prose p { font-size: 0.98rem; line-height: 1.8; color: var(--text); margin-bottom: 1.25em; }
.ss-criteria__grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(290px, 1fr)); gap: 2rem; }
.ss-criteria__item h3 { font-family: var(--font-display); font-size: 1.05rem; color: var(--accent, #1B3A5C); margin: 0 0 0.6rem; }
.ss-criteria__item p { font-size: 0.9rem; line-height: 1.75; color: var(--text-muted); margin: 0; }
.ss-process__list { list-style: none; padding: 0; margin: 0; counter-reset: process; display: flex; flex-direction: column; gap: 0; }
.ss-process__list li { counter-increment: process; display: grid; grid-template-columns: 2.5rem 1fr; gap: 0.5rem 1.25rem; padding: 1.5rem 0; border-bottom: 1px solid var(--rule); }
.ss-process__list li:last-child { border-bottom: none; }
.ss-process__list li::before { content: counter(process); font-size: 1rem; font-weight: 700; color: var(--accent, #1B3A5C); background: rgba(27,58,92,0.07); border-radius: 50%; width: 2.25rem; height: 2.25rem; display: flex; align-items: center; justify-content: center; flex-shrink: 0; margin-top: 0.1rem; }
.ss-process__list li strong { display: block; grid-column: 2; font-size: 0.98rem; color: var(--text); margin-bottom: 0.3rem; }
.ss-process__list li span { display: block; grid-column: 2; font-size: 0.88rem; line-height: 1.7; color: var(--text-muted); }
.ss-related { max-width: 900px; }
.ss-related .label { margin-bottom: 1.5rem; }
.ss-related__links { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 1.25rem; }
.gme-subpage__card { display: block; border: 1px solid var(--rule); border-radius: 8px; padding: 1.5rem 1.75rem; text-decoration: none; color: var(--text); transition: border-color 0.15s; }
.gme-subpage__card:hover { border-color: var(--accent, #1B3A5C); }
.gme-subpage__label { font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.08em; color: var(--text-muted); display: block; margin-bottom: 0.5rem; }
.gme-subpage__card h3 { font-family: var(--font-display); font-size: 1rem; color: var(--accent, #1B3A5C); margin: 0 0 0.5rem; line-height: 1.3; }
.gme-subpage__card p { font-size: 0.85rem; line-height: 1.6; color: var(--text-muted); margin: 0 0 0.75rem; }
.gme-subpage__link { font-size: 0.82rem; font-weight: 600; color: var(--accent, #1B3A5C); }
</style>
