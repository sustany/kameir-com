---
import Base from '../../../layouts/Base.astro';

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "US Market Entry Advisory for German Companies",
  "description": "Independent advisory helping German manufacturers, energy developers, and industrials establish US operations, capture federal incentives under the IRA and CHIPS Act, and connect with private capital. Bilingual German/English, retainer-based.",
  "provider": {
    "@type": "Person",
    "name": "Christian Kameir",
    "url": "https://kameir.com",
    "address": { "@type": "PostalAddress", "addressLocality": "Newport Beach", "addressRegion": "CA", "addressCountry": "US" }
  },
  "areaServed": [{ "@type": "Country", "name": "United States" }, { "@type": "Country", "name": "Germany" }],
  "serviceType": "US Market Entry Consulting",
  "inLanguage": ["en", "de"],
  "url": "https://kameir.com/advisory/german-companies-us-market-entry"
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://kameir.com" },
    { "@type": "ListItem", "position": 2, "name": "Advisory", "item": "https://kameir.com/advisory" },
    { "@type": "ListItem", "position": 3, "name": "German Companies — US Market Entry", "item": "https://kameir.com/advisory/german-companies-us-market-entry" }
  ]
};
---

<Base
  title="US Market Entry for German Companies — Advisory | Christian Kameir"
  description="Independent advisory helping German manufacturers, energy developers, and industrials enter the US market — site selection, IRA incentives, and private capital. Bilingual German/English. Newport Beach, CA."
  canonicalUrl="https://kameir.com/advisory/german-companies-us-market-entry"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  </Fragment>

  <article class="advisory">

    <section class="advisory__hero">
      <div class="advisory__hero-inner container--wide">
        <div class="advisory__hero-text">
          <p class="label advisory__location">Newport Beach, California · Bilingual German / English</p>
          <h1 class="advisory__name">US Market Entry<br>for German Companies</h1>
          <p class="advisory__tagline">The American market does not reward patience. It rewards preparation.</p>

          <div class="advisory__bio prose">
            <p>
              German manufacturers, energy developers, and capital-intensive industrials face a specific set of problems when entering the United States: a patchwork of federal, state, and county incentives that interact in non-obvious ways; a capital market that values relationships over credentials; and a regulatory environment that rewards operators who understand it from the inside.
            </p>
            <p>
              This practice exists for that client. Bilingual German&thinsp;/&thinsp;English. Based in Newport Beach with an operational footprint in New Mexico. Retained engagements, not hourly. The roster is deliberately small — no more than a handful of clients at any time — because the depth of involvement each engagement requires cannot be diluted.
            </p>
            <p>
              Scope covers the full entry arc: initial market assessment, site selection across candidate states, incentive capture under the Inflation Reduction Act and CHIPS Act, corporate structuring, and connection to the private capital sources that complete the financing stack.
            </p>
          </div>

          <div class="advisory__cta">
            <a href="/contact" class="btn btn--primary">Request an introduction</a>
            <a href="/about" class="btn btn--outline">About Christian</a>
          </div>
        </div>

        <div class="advisory__hero-photo">
          <picture>
            <source srcset="/images/christian-kameir.webp" type="image/webp" />
            <img src="/images/christian-kameir.jpg" alt="Christian Kameir" width="460" height="575"
              class="advisory__photo" loading="eager" fetchpriority="high" />
          </picture>
        </div>
      </div>
    </section>

    <div class="container"><hr class="rule" /></div>

    <!-- What the engagement covers -->
    <section class="gme-section">
      <div class="container">
        <p class="label">Engagement scope</p>
        <div class="gme-scope__grid">
          <div class="gme-scope__item">
            <h2>Market Assessment</h2>
            <p>Before a site is selected or a dollar committed, this practice maps the actual competitive and regulatory landscape for your specific sector — not the landscape as described in state promotional materials. German companies are often surprised by the gap between the two.</p>
            <p>Output: a written assessment that identifies the states and incentive structures genuinely available to your company, the capital sources that fund comparable projects, and the structural traps that have caught comparable entrants.</p>
          </div>
          <div class="gme-scope__item">
            <h2>Site Selection</h2>
            <p>Manufacturer site selection in the US is simultaneously a real estate, regulatory, workforce, and incentive negotiation. The practice does not accept referral fees from states, counties, or site-selection intermediaries — which means the analysis is done for the client, not for whoever pays the introduction fee.</p>
            <p>See the dedicated <a href="/advisory/us-site-selection-german-manufacturers">site selection page →</a></p>
          </div>
          <div class="gme-scope__item">
            <h2>Federal Incentive Capture</h2>
            <p>The Inflation Reduction Act and CHIPS Act created the largest US industrial incentive programs in decades. The rules for who qualifies — and how — are complex, frequently updated, and in some cases require specific corporate structuring decisions made before ground is broken.</p>
            <p>See the dedicated <a href="/advisory/ira-incentives-german-companies">IRA incentives page →</a></p>
          </div>
          <div class="gme-scope__item">
            <h2>Capital Sourcing</h2>
            <p>US private capital — family offices, project finance lenders, infrastructure funds — operates on relationship logic that differs from European institutional capital. The practice maintains direct working relationships with capital sources relevant to capital-intensive industrial and energy projects and does not intermediate on commission.</p>
          </div>
          <div class="gme-scope__item">
            <h2>Corporate Structuring</h2>
            <p>Delaware C-corp, LLC, LP, or something more bespoke — the right structure depends on the incentive programs being pursued, the capital being raised, and the parent company's repatriation objectives. The practice works alongside US counsel rather than replacing it.</p>
          </div>
          <div class="gme-scope__item">
            <h2>Ongoing Advisory</h2>
            <p>After the initial market entry is complete, some clients retain the practice for ongoing fractional advisory — regulatory monitoring, capital market navigation, and board-level strategic input. Minimum twelve-month commitment.</p>
          </div>
        </div>
      </div>
    </section>

    <div class="container"><hr class="rule" /></div>

    <!-- Terms -->
    <section class="advisory__anchors">
      <div class="container">
        <p class="label">Engagement terms</p>
        <dl class="anchors__dl">
          <div class="anchors__item">
            <dt>Engagement floor</dt>
            <dd>$18,000&thinsp;/&thinsp;month ($22,000 for US-entry onshoring engagements)</dd>
          </div>
          <div class="anchors__item">
            <dt>Minimums</dt>
            <dd>Six months on capital and onshoring engagements. Twelve months on fractional advisory.</dd>
          </div>
          <div class="anchors__item">
            <dt>Terms</dt>
            <dd>Net-15. First month on signature.</dd>
          </div>
          <div class="anchors__item">
            <dt>Languages</dt>
            <dd>English and German. All client deliverables available in either language.</dd>
          </div>
          <div class="anchors__item">
            <dt>What this practice does not do</dt>
            <dd>Referral fees from US states or counties. Contingent-only structures. Grant ghost-writing of record. Hourly engagements.</dd>
          </div>
        </dl>
      </div>
    </section>

    <div class="container"><hr class="rule" /></div>

    <!-- Sub-page links -->
    <section class="gme-subpages">
      <div class="container">
        <p class="label">Go deeper</p>
        <div class="gme-subpages__grid">
          <a href="/advisory/us-site-selection-german-manufacturers" class="gme-subpage__card">
            <span class="gme-subpage__label">Site Selection</span>
            <h3>US Site Selection for German Manufacturers</h3>
            <p>How to evaluate US states and counties without relying on materials produced by people who are paid to sell you a location.</p>
            <span class="gme-subpage__link">Read more →</span>
          </a>
          <a href="/advisory/ira-incentives-german-companies" class="gme-subpage__card">
            <span class="gme-subpage__label">Federal Incentives</span>
            <h3>IRA Incentives for German Companies</h3>
            <p>The Inflation Reduction Act's tax credits, grants, and loan programs — and what German manufacturers actually qualify for.</p>
            <span class="gme-subpage__link">Read more →</span>
          </a>
        </div>
      </div>
    </section>

    <div class="container"><hr class="rule" /></div>

    <section class="advisory__anchors">
      <div class="container">
        <p class="advisory__cta-label">Ready to explore an engagement?</p>
        <div class="advisory__cta" style="margin-top:1rem;">
          <a href="/contact" class="btn btn--primary">Request an introduction</a>
        </div>
      </div>
    </section>

  </article>
</Base>

<style>
/* Inherit advisory layout styles from global CSS */
.advisory__hero { padding-top: 5rem; padding-bottom: var(--space-xl); padding-inline: var(--space-m); }
.advisory__hero-inner { display: grid; grid-template-columns: 1fr 380px; gap: 5rem; align-items: center; margin-inline: auto; max-width: 1200px; }
.advisory__location { margin-bottom: 1.25rem; }
.advisory__name { font-family: var(--font-display); font-size: clamp(2.2rem, 5vw, 3.8rem); font-weight: 700; line-height: 1.05; letter-spacing: -0.03em; color: var(--text); margin-bottom: 1.5rem; }
.advisory__tagline { font-family: var(--font-display); font-style: italic; font-size: clamp(1rem, 2.2vw, 1.2rem); color: var(--text-muted); line-height: 1.5; max-width: 460px; margin-bottom: var(--space-m); padding-bottom: var(--space-m); border-bottom: 1px solid var(--rule); }
.advisory__bio { font-size: 0.98rem; line-height: 1.8; color: var(--text); max-width: 500px; margin-bottom: var(--space-l); }
.advisory__bio p { margin-bottom: 1em; }
.advisory__cta { display: flex; gap: 1rem; flex-wrap: wrap; }
.advisory__hero-photo { display: flex; align-items: flex-start; justify-content: flex-end; }
.advisory__photo { width: 100%; max-width: 380px; aspect-ratio: 4/5; object-fit: cover; object-position: center top; border-radius: 1px; display: block; filter: grayscale(12%); }
.advisory__anchors { padding-bottom: var(--space-xl); padding-top: var(--space-l); }
.advisory__anchors .label { margin-bottom: 1.5rem; }
.anchors__dl { display: flex; flex-direction: column; gap: 1rem; }
.anchors__item { display: grid; grid-template-columns: 260px 1fr; gap: 1rem; align-items: baseline; }
.anchors__item dt { font-size: 0.9rem; font-weight: 600; color: var(--text); }
.anchors__item dd { font-size: 0.9rem; color: var(--text-muted); line-height: 1.6; }

/* Scope grid */
.gme-section { padding: var(--space-xl) var(--space-m); }
.gme-section .label { margin-bottom: 2rem; }
.gme-scope__grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 2.5rem; max-width: 1100px; }
.gme-scope__item h2 { font-family: var(--font-display); font-size: 1.2rem; color: var(--accent, #1B3A5C); margin: 0 0 0.75rem; }
.gme-scope__item p { font-size: 0.92rem; line-height: 1.75; color: var(--text-muted); margin-bottom: 0.5em; }
.gme-scope__item a { color: var(--accent, #1B3A5C); font-weight: 600; }

/* Sub-page cards */
.gme-subpages { padding: var(--space-l) var(--space-m); }
.gme-subpages .label { margin-bottom: 1.5rem; }
.gme-subpages__grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 1.5rem; max-width: 860px; }
.gme-subpage__card { display: block; border: 1px solid var(--rule); border-radius: 8px; padding: 1.75rem; text-decoration: none; color: var(--text); transition: border-color 0.15s, box-shadow 0.15s; }
.gme-subpage__card:hover { border-color: var(--accent, #1B3A5C); box-shadow: 0 2px 12px rgba(27,58,92,0.08); }
.gme-subpage__label { font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.08em; color: var(--text-muted); display: block; margin-bottom: 0.6rem; }
.gme-subpage__card h3 { font-family: var(--font-display); font-size: 1.1rem; color: var(--accent, #1B3A5C); margin: 0 0 0.6rem; line-height: 1.3; }
.gme-subpage__card p { font-size: 0.88rem; line-height: 1.65; color: var(--text-muted); margin: 0 0 1rem; }
.gme-subpage__link { font-size: 0.85rem; font-weight: 600; color: var(--accent, #1B3A5C); }
.advisory__cta-label { font-family: var(--font-display); font-size: 1.25rem; color: var(--text); font-style: italic; }

@media (max-width: 768px) {
  .advisory__hero-inner { grid-template-columns: 1fr; gap: var(--space-l); }
  .advisory__hero-photo { order: -1; }
  .advisory__photo { max-width: 200px; }
  .anchors__item { grid-template-columns: 1fr; gap: 0.2rem; }
  .advisory__hero { padding-top: 3rem; }
}
</style>
