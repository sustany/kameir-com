---
import Base from '../../../layouts/Base.astro';

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "IRA Incentives Advisory for German Companies",
  "description": "Advisory on Inflation Reduction Act tax credits, grants, and loan programs available to German manufacturers and energy companies entering the US market. Includes structuring guidance to maximize eligibility.",
  "provider": {
    "@type": "Person",
    "name": "Christian Kameir",
    "url": "https://kameir.com"
  },
  "areaServed": { "@type": "Country", "name": "United States" },
  "serviceType": "Federal Incentives Advisory",
  "inLanguage": ["en", "de"],
  "url": "https://kameir.com/advisory/ira-incentives-german-companies"
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://kameir.com" },
    { "@type": "ListItem", "position": 2, "name": "Advisory", "item": "https://kameir.com/advisory" },
    { "@type": "ListItem", "position": 3, "name": "German Companies — US Market Entry", "item": "https://kameir.com/advisory/german-companies-us-market-entry" },
    { "@type": "ListItem", "position": 4, "name": "IRA Incentives", "item": "https://kameir.com/advisory/ira-incentives-german-companies" }
  ]
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Can German companies qualify for IRA tax credits?",
      "acceptedAnswer": { "@type": "Answer", "text": "Yes. Foreign-owned companies that manufacture or operate qualifying facilities in the United States can access most IRA incentives, including the Investment Tax Credit (Section 48), the Advanced Manufacturing Production Credit (Section 45X), and the Clean Hydrogen Credit (Section 45V). Eligibility depends on the specific credit, the domestic content requirements, and the corporate structure of the US entity." }
    },
    {
      "@type": "Question",
      "name": "What is the domestic content bonus under the IRA?",
      "acceptedAnswer": { "@type": "Answer", "text": "The IRA provides an additional tax credit — typically 10 percentage points — for projects that meet domestic content requirements for steel, iron, and manufactured components. German manufacturers establishing US production facilities often qualify for this bonus on components manufactured domestically, which can significantly increase the total incentive value." }
    },
    {
      "@type": "Question",
      "name": "Can IRA tax credits be transferred or sold?",
      "acceptedAnswer": { "@type": "Answer", "text": "Yes. The IRA introduced transferability provisions that allow eligible taxpayers to sell certain tax credits to unrelated third parties. This is particularly valuable for German companies in early-stage US operations that do not yet have sufficient US tax liability to fully utilize the credits directly." }
    }
  ]
};
---

<Base
  title="IRA Incentives for German Companies Entering the US — Christian Kameir"
  description="Inflation Reduction Act tax credits and grants available to German manufacturers, energy developers, and industrials entering the US. ITC, 45X, 45V, domestic content bonuses, and transferability — advisory by Christian Kameir."
  canonicalUrl="https://kameir.com/advisory/ira-incentives-german-companies"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  </Fragment>

  <article class="advisory">

    <section class="advisory__hero">
      <div class="container">
        <nav class="ss-breadcrumb">
          <a href="/advisory">Advisory</a>
          <span>›</span>
          <a href="/advisory/german-companies-us-market-entry">US Market Entry</a>
          <span>›</span>
          <span>IRA Incentives</span>
        </nav>

        <div class="ss-hero__text">
          <p class="label">Inflation Reduction Act · German Companies</p>
          <h1 class="ss-hero__h1">IRA Incentives for German<br>Manufacturers in the US</h1>
          <p class="ss-hero__lead">
            The Inflation Reduction Act created the largest federal industrial incentive program in US history. German manufacturers establishing US operations can access tax credits, grants, and low-cost loans that materially change project economics — but only if the corporate structure, domestic content sourcing, and prevailing wage compliance are designed correctly from the start.
          </p>
          <div class="advisory__cta" style="margin-top: 2rem;">
            <a href="/contact" class="btn btn--primary">Discuss IRA eligibility</a>
            <a href="/advisory/german-companies-us-market-entry" class="btn btn--outline">Full market entry scope →</a>
          </div>
        </div>
      </div>
    </section>

    <div class="container"><hr class="rule" /></div>

    <!-- Key credits -->
    <section class="ira-section">
      <div class="container">
        <p class="label">Key incentive programs</p>
        <div class="ira-credits__grid">

          <div class="ira-credit__card">
            <div class="ira-credit__code">§ 48 / 48E</div>
            <h3>Investment Tax Credit</h3>
            <p>A direct percentage credit on eligible capital costs for clean energy facilities — solar, wind, battery storage, and certain industrial heat applications. Base rate of 6%, rising to 30% with prevailing wage and apprenticeship compliance. An additional 10-point domestic content bonus applies when steel, iron, and manufactured components meet US sourcing thresholds.</p>
            <p class="ira-credit__note">Relevant for: energy-intensive manufacturers, renewable energy developers, battery and storage projects.</p>
          </div>

          <div class="ira-credit__card">
            <div class="ira-credit__code">§ 45X</div>
            <h3>Advanced Manufacturing Production Credit</h3>
            <p>A per-unit production credit for domestic manufacturing of solar components, wind components, inverters, battery cells, modules, and critical minerals. Unlike investment credits, 45X does not require a fixed capital expenditure — the credit scales with production volume. German manufacturers producing these components in US facilities can qualify beginning with the first unit produced.</p>
            <p class="ira-credit__note">Relevant for: solar panel manufacturers, battery cell and module producers, wind component manufacturers.</p>
          </div>

          <div class="ira-credit__card">
            <div class="ira-credit__code">§ 45V</div>
            <h3>Clean Hydrogen Production Credit</h3>
            <p>A production credit for clean hydrogen based on lifecycle greenhouse gas emissions. German chemical and industrial gas companies with hydrogen production operations are among the most natural candidates. The credit ranges from $0.60 to $3.00 per kilogram depending on the emissions intensity of the production process. Requires third-party lifecycle analysis and EPA registration.</p>
            <p class="ira-credit__note">Relevant for: chemical manufacturers, industrial gas producers, hydrogen infrastructure developers.</p>
          </div>

          <div class="ira-credit__card">
            <div class="ira-credit__code">§ 45Q</div>
            <h3>Carbon Capture Credit</h3>
            <p>A per-tonne credit for carbon captured and sequestered or utilized. German industrial companies with carbon-intensive processes — cement, steel, chemicals — that are installing carbon capture equipment at US facilities can access this credit beginning with the first tonne captured. The credit runs for twelve years from the date the facility is placed in service.</p>
            <p class="ira-credit__note">Relevant for: cement producers, steel manufacturers, chemical processors, industrial carbon capture projects.</p>
          </div>

          <div class="ira-credit__card">
            <div class="ira-credit__code">DOE Loans</div>
            <h3>Title 17 & ATVM Loan Programs</h3>
            <p>The Department of Energy's Loan Programs Office provides direct loans and loan guarantees for innovative energy projects and advanced technology vehicle manufacturing. German companies establishing qualifying US facilities can access low-cost capital that is typically unavailable through commercial lending at comparable project stage. DOE loan applications are complex and relationship-dependent.</p>
            <p class="ira-credit__note">Relevant for: advanced manufacturing, clean energy generation and storage, vehicle and component manufacturers.</p>
          </div>

          <div class="ira-credit__card">
            <div class="ira-credit__code">Transferability</div>
            <h3>Credit Monetization</h3>
            <p>The IRA allows most clean energy tax credits to be sold to unrelated third parties for cash. This is critical for German companies in early US operations that do not yet have sufficient US tax liability to utilize credits directly. A properly structured transfer allows the economic value of the credit to be realized immediately, rather than carried forward over years.</p>
            <p class="ira-credit__note">Relevant for: any company with insufficient US tax basis to absorb credits directly.</p>
          </div>

        </div>
      </div>
    </section>

    <div class="container"><hr class="rule" /></div>

    <!-- Structuring decisions -->
    <section class="ira-section">
      <div class="container">
        <h2 class="ss-section__h2">Structuring Decisions That Determine Eligibility</h2>
        <div class="ss-prose">
          <p>
            The most common mistake German companies make with US federal incentives is treating them as a financing detail to be resolved after the project is underway. Most IRA credits require specific decisions — about corporate structure, domestic content sourcing, prevailing wage practices, and facility design — that must be made before ground is broken. Changes made after construction begins often cannot be retroactively applied.
          </p>
          <p>
            This practice advises on the structuring decisions that affect IRA eligibility at the earliest stage of market entry planning — specifically because those decisions are hardest and most expensive to undo later. This includes entity structure (the IRS treats a US LLC owned by a German GmbH differently from a US C-corp in several credit contexts), domestic content sourcing commitments, and the prevailing wage and apprenticeship requirements that determine whether the base credit rate or the enhanced rate applies.
          </p>
          <p>
            The practice works alongside US tax counsel rather than replacing it. Eligibility analysis and strategic structuring are the advisory's contribution; formal tax opinion and IRS registration are handled by qualified tax counsel.
          </p>
        </div>
      </div>
    </section>

    <div class="container"><hr class="rule" /></div>

    <!-- FAQ -->
    <section class="ira-section">
      <div class="container">
        <p class="label">Common questions</p>
        <div class="ira-faq__list">
          <details class="ira-faq__item">
            <summary>Can a German company — not a US company — qualify for IRA credits?</summary>
            <p>Foreign-owned companies can qualify, provided the qualifying facility or production activity is located in the United States and the US entity is properly structured. The credit accrues to the US entity, not the German parent. The specific requirements vary by credit section.</p>
          </details>
          <details class="ira-faq__item">
            <summary>What is the domestic content bonus and does a German manufacturer qualify?</summary>
            <p>The domestic content bonus — typically 10 additional percentage points on the ITC — requires that steel and iron used in the project be produced in the US, and that a specified percentage of manufactured components by cost be produced domestically. German manufacturers establishing US component production may qualify for this bonus on the domestically produced portion. The eligibility analysis must be done project by project.</p>
          </details>
          <details class="ira-faq__item">
            <summary>Can IRA tax credits be transferred or sold to third parties?</summary>
            <p>Yes. The IRA introduced transferability for most clean energy credits. An eligible taxpayer can sell credits to an unrelated buyer for cash. This allows German companies with limited current US tax liability to monetize credits immediately rather than carrying them forward. The transfer must be structured correctly to avoid recapture risk.</p>
          </details>
          <details class="ira-faq__item">
            <summary>How do IRA credits interact with state incentive packages?</summary>
            <p>IRA credits and state incentive packages generally stack — the federal credit does not reduce the value of state grants or tax exemptions. However, certain state incentive structures can create complications with federal credit calculations, particularly in cases where state grants reduce the basis used to calculate the ITC. The interaction must be modeled for each specific incentive combination.</p>
          </details>
          <details class="ira-faq__item">
            <summary>What happens to IRA credits if the political environment changes?</summary>
            <p>Credits that have already been earned and claimed are generally protected. The risk is to credits that have not yet been claimed — if the underlying program is repealed or modified by future legislation, the terms of that legislation determine what happens to projects already underway. Projects that are fully placed in service before a legislative change are generally protected; projects still under construction at the time of a change face more uncertainty. This is a known risk that this practice models explicitly in its engagement analysis.</p>
          </details>
        </div>
      </div>
    </section>

    <div class="container"><hr class="rule" /></div>

    <section class="ira-section">
      <div class="container ss-related">
        <p class="label">Related</p>
        <div class="ss-related__links">
          <a href="/advisory/us-site-selection-german-manufacturers" class="gme-subpage__card">
            <span class="gme-subpage__label">Site Selection</span>
            <h3>US Site Selection for German Manufacturers</h3>
            <p>IRA incentives are only part of the location equation. Site selection advisory that evaluates locations without referral fees from promoters.</p>
            <span class="gme-subpage__link">Read more →</span>
          </a>
          <a href="/advisory/german-companies-us-market-entry" class="gme-subpage__card">
            <span class="gme-subpage__label">Full Scope</span>
            <h3>US Market Entry for German Companies</h3>
            <p>From market assessment to capital sourcing — the full engagement arc for German companies entering the United States.</p>
            <span class="gme-subpage__link">Read more →</span>
          </a>
        </div>
        <div style="margin-top: 2.5rem;">
          <a href="/contact" class="btn btn--primary">Discuss IRA eligibility for your project</a>
        </div>
      </div>
    </section>

  </article>
</Base>

<style>
.advisory__hero { padding-top: 4rem; padding-bottom: var(--space-xl); padding-inline: var(--space-m); }
.advisory__cta { display: flex; gap: 1rem; flex-wrap: wrap; }
.ss-breadcrumb { display: flex; gap: 0.5rem; align-items: center; font-size: 0.82rem; color: var(--text-muted); margin-bottom: 2rem; }
.ss-breadcrumb a { color: var(--text-muted); text-decoration: none; }
.ss-breadcrumb a:hover { color: var(--accent, #1B3A5C); }
.ss-hero__h1 { font-family: var(--font-display); font-size: clamp(1.9rem, 4.5vw, 3rem); font-weight: 700; line-height: 1.15; letter-spacing: -0.02em; color: var(--text); margin: 1rem 0 1.25rem; }
.ss-hero__lead { font-size: 1.05rem; line-height: 1.75; color: var(--text-muted); max-width: 660px; }
.ira-section { padding: var(--space-xl) var(--space-m); }
.ira-section .label { margin-bottom: 1.75rem; }
.ss-section__h2 { font-family: var(--font-display); font-size: clamp(1.4rem, 3vw, 2rem); color: var(--text); margin: 0 0 1.5rem; }
.ss-prose { max-width: 680px; }
.ss-prose p { font-size: 0.98rem; line-height: 1.8; color: var(--text); margin-bottom: 1.25em; }
.ira-credits__grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 1.75rem; }
.ira-credit__card { border: 1px solid var(--rule); border-radius: 8px; padding: 1.5rem 1.75rem; }
.ira-credit__code { font-family: var(--font-mono, 'Courier New', monospace); font-size: 0.78rem; font-weight: 700; letter-spacing: 0.05em; color: var(--accent, #1B3A5C); background: rgba(27,58,92,0.07); display: inline-block; padding: 0.2rem 0.5rem; border-radius: 4px; margin-bottom: 0.6rem; }
.ira-credit__card h3 { font-family: var(--font-display); font-size: 1.05rem; color: var(--text); margin: 0 0 0.75rem; }
.ira-credit__card p { font-size: 0.88rem; line-height: 1.72; color: var(--text-muted); margin-bottom: 0.75em; }
.ira-credit__note { font-size: 0.82rem !important; color: var(--text-muted); font-style: italic; border-top: 1px solid var(--rule); padding-top: 0.5rem; margin-bottom: 0 !important; }
.ira-faq__list { display: flex; flex-direction: column; max-width: 740px; }
.ira-faq__item { border-bottom: 1px solid var(--rule); }
.ira-faq__item summary { cursor: pointer; padding: 1.1rem 0; font-weight: 600; font-size: 0.98rem; color: var(--text); list-style: none; display: flex; justify-content: space-between; align-items: center; gap: 1rem; }
.ira-faq__item summary::after { content: '+'; font-size: 1.25rem; color: var(--accent, #1B3A5C); flex-shrink: 0; }
.ira-faq__item[open] summary::after { content: '−'; }
.ira-faq__item p { padding: 0 0 1rem; margin: 0; font-size: 0.9rem; color: var(--text-muted); line-height: 1.72; }
.ss-related { max-width: 900px; }
.ss-related .label { margin-bottom: 1.5rem; }
.ss-related__links { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 1.25rem; }
.gme-subpage__card { display: block; border: 1px solid var(--rule); border-radius: 8px; padding: 1.5rem 1.75rem; text-decoration: none; color: var(--text); transition: border-color 0.15s; }
.gme-subpage__card:hover { border-color: var(--accent, #1B3A5C); }
.gme-subpage__label { font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.08em; color: var(--text-muted); display: block; margin-bottom: 0.5rem; }
.gme-subpage__card h3 { font-family: var(--font-display); font-size: 1rem; color: var(--accent, #1B3A5C); margin: 0 0 0.5rem; line-height: 1.3; }
.gme-subpage__card p { font-size: 0.85rem; line-height: 1.6; color: var(--text-muted); margin: 0 0 0.75rem; }
.gme-subpage__link { font-size: 0.82rem; font-weight: 600; color: var(--accent, #1B3A5C); }
</style>
