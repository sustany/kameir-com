<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Christian Kameir</title>
  <meta name="description" content="Author and speaker on AI ethics for law firms." />
  <meta name="robots" content="index, follow" />
  <link rel="canonical" href="https://kameir.com" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
  <script defer data-domain="kameir.com" src="https://plausible.io/js/script.js"></script>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html, body { height: 100%; }
    body {
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Helvetica, Arial, sans-serif;
      color: #e8e8ec;
      display: flex;
      flex-direction: column;
      min-height: 100vh;
      position: relative;
      overflow-x: hidden;
    }
    .bg {
      position: fixed;
      inset: 0;
      z-index: 0;
      background:
        radial-gradient(ellipse 80% 60% at 15% 55%, rgba(18,28,64,0.9) 0%, transparent 70%),
        radial-gradient(ellipse 60% 50% at 85% 25%, rgba(12,20,48,0.7) 0%, transparent 60%),
        radial-gradient(ellipse 100% 80% at 50% 100%, rgba(8,12,28,0.95) 0%, transparent 70%),
        linear-gradient(165deg, #0b0e18 0%, #0d1220 35%, #090c16 65%, #07080d 100%);
    }
    .bg::after {
      content: '';
      position: absolute;
      inset: 0;
      background: radial-gradient(ellipse at center, transparent 40%, rgba(0,0,0,0.5) 100%);
    }
    main {
      flex: 1;
      display: flex;
      align-items: center;
      padding: 3rem 2.5rem;
      position: relative;
      z-index: 1;
    }
    h1 {
      font-size: clamp(2rem, 5.5vw, 3.25rem);
      font-weight: 300;
      letter-spacing: -0.025em;
      color: #f0f0f5;
      margin-bottom: 0.45rem;
      line-height: 1.08;
    }
    .sub {
      font-size: 0.75rem;
      color: rgba(255,255,255,0.28);
      letter-spacing: 0.16em;
      text-transform: uppercase;
      margin-bottom: 2.5rem;
    }
    nav {
      display: flex;
      gap: 1.75rem;
      flex-wrap: wrap;
    }
    nav a {
      font-size: 0.78rem;
      color: rgba(255,255,255,0.38);
      text-decoration: none;
      letter-spacing: 0.05em;
      transition: color 0.2s ease;
      border-bottom: 1px solid rgba(255,255,255,0.08);
      padding-bottom: 2px;
    }
    nav a:hover {
      color: rgba(255,255,255,0.85);
      border-bottom-color: rgba(255,255,255,0.3);
    }
    footer {
      position: relative;
      z-index: 1;
      border-top: 1px solid rgba(255,255,255,0.05);
      padding: 1.1rem 2.5rem;
      display: flex;
      justify-content: space-between;
      align-items: center;
      font-size: 0.6875rem;
      color: rgba(255,255,255,0.18);
    }
    footer a {
      color: rgba(255,255,255,0.18);
      text-decoration: none;
      margin-left: 1.25rem;
      transition: color 0.2s;
    }
    footer a:hover { color: rgba(255,255,255,0.5); }
  </style>
</head>
<body>
  <div class="bg"></div>
  <main>
    <div>
      <h1>Christian Kameir</h1>
      <p class="sub">Author &middot; Speaker</p>
      <nav>
        <a href="/writing">Writing</a>
        <a href="/about">About</a>
        <a href="/speaking">Speaking</a>
        <a href="/contact">Contact</a>
      </nav>
    </div>
  </main>
  <footer>
    <span>&copy; 2026 Kameir &amp; Co LLC</span>
    <span>
      <a href="/privacy">Privacy</a>
      <a href="https://www.linkedin.com/in/kameir/" target="_blank" rel="noopener">LinkedIn</a>
    </span>
  </footer>
</body>
</html>