---
import Base from '../layouts/Base.astro';
---

<Base
  title="Christian Kameir"
  description="Independent advisory helping capital-intensive companies from German-speaking countries enter the US market, capture federal and state incentives, and connect with private capital."
>
  <article class="home">

    <!-- ── Hero ──────────────────────────────────────────── -->
    <section class="home__hero">
      <div class="container">
        <p class="label">Newport Beach, California</p>
        <h1 class="home__name">Christian Kameir</h1>
        <p class="home__tagline">Reality does not have an advertising budget.</p>
      </div>
    </section>

    <!-- ── Rule ─────────────────────────────────────────── -->
    <div class="container"><hr class="rule" /></div>

    <!-- ── Intro ─────────────────────────────────────────── -->
    <section class="home__intro">
      <div class="container">
        <div class="prose">
          <p>
            Independent advisory based in Newport Beach, California, with an operational
            footprint in New Mexico. The practice helps capital-intensive companies —
            primarily industrials, energy developers, and advanced manufacturers from
            German-speaking countries — enter the United States market, capture the
            federal, state, and county incentives available to them, and connect with
            the private capital sources that complete the stack.
          </p>
          <p>
            Bilingual German&thinsp;/&thinsp;English. Operates what it advises on rather
            than consulting from the sidelines. Does not accept referral fees from US
            states, counties, or site-selection intermediaries. Engagements are retained,
            paid, and scoped — not hourly.
          </p>
          <p>
            The active roster is deliberately small. At any given time the practice
            represents no more than a handful of clients, because the depth of involvement
            each engagement demands cannot be scaled by adding accounts. When the roster
            is full, new inquiries are declined or deferred.
          </p>
        </div>

        <div class="home__cta">
          <a href="/about" class="btn btn--primary">The practice</a>
          <a href="/contact" class="btn btn--outline">Request a call</a>
        </div>
      </div>
    </section>

    <!-- ── Rule ─────────────────────────────────────────── -->
    <div class="container"><hr class="rule" /></div>

    <!-- ── Anchors ───────────────────────────────────────── -->
    <section class="home__anchors">
      <div class="container">
        <p class="label">Practice anchors</p>
        <dl class="anchors__dl">
          <div class="anchors__item">
            <dt>Engagement floor</dt>
            <dd>$18,000&thinsp;/&thinsp;month ($22,000 for US-entry onshoring)</dd>
          </div>
          <div class="anchors__item">
            <dt>Minimums</dt>
            <dd>Six months on capital and onshoring engagements. Twelve months on fractional advisory.</dd>
          </div>
          <div class="anchors__item">
            <dt>Terms</dt>
            <dd>Net-15. First month on signature.</dd>
          </div>
          <div class="anchors__item">
            <dt>What Kameir does not do</dt>
            <dd>Referral fees from US states. Contingent-only structures. Grant ghost-writing of record.</dd>
          </div>
        </dl>
      </div>
    </section>

  </article>
</Base>

<style>
/* ── Hero ─────────────────────────────────────────────────── */
.home__hero {
  padding-top: 5rem;
  padding-bottom: 0;
}

.home__hero .label {
  margin-bottom: 1.5rem;
}

.home__name {
  font-family: var(--font-display);
  font-size: clamp(2rem, 5.5vw, 3.5rem);
  font-weight: 700;
  line-height: 1.1;
  letter-spacing: -0.02em;
  white-space: nowrap;
  color: var(--text);
  margin-bottom: 1.5rem;
}

.home__tagline {
  font-family: var(--font-display);
  font-style: italic;
  font-size: clamp(1.15rem, 3vw, 1.45rem);
  color: var(--text-muted);
  line-height: 1.5;
  max-width: 520px;
}

/* ── Intro ─────────────────────────────────────────────────── */
.home__intro {
  padding-bottom: var(--space-l);
}

.home__intro .prose {
  font-size: 1.05rem;
  line-height: 1.85;
}

.home__cta {
  display: flex;
  gap: 1rem;
  margin-top: var(--space-l);
  flex-wrap: wrap;
}

/* ── Anchors ───────────────────────────────────────────────── */
.home__anchors {
  padding-bottom: var(--space-xl);
}

.home__anchors .label {
  margin-bottom: 1.5rem;
}

.anchors__dl {
  display: flex;
  flex-direction: column;
  gap: 1rem;
}

.anchors__item {
  display: grid;
  grid-template-columns: 220px 1fr;
  gap: 1rem;
  align-items: baseline;
}

.anchors__item dt {
  font-size: 0.9rem;
  font-weight: 600;
  color: var(--text);
}

.anchors__item dd {
  font-size: 0.9rem;
  color: var(--text-muted);
  line-height: 1.6;
}

@media (max-width: 480px) {
  .home__cta { flex-direction: column; }
  .home__cta .btn { text-align: center; }
  .anchors__item { grid-template-columns: 1fr; gap: 0.2rem; }
}
</style>
