---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import '../styles/home.css';

const allPosts = await getCollection('writing', ({ data }) => !data.draft);
const recentPosts = allPosts
  .sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime())
  .slice(0, 4);

const fmt = new Intl.DateTimeFormat('en-US', {
  year: 'numeric',
  month: 'long',
});
---

<Base
  title="Christian Kameir"
  description="Advisor, author, and speaker. Helping German-speaking companies enter the US market, speaking on AI and the future of money, and publishing practical AI ethics guides for practitioners."
  personSchema={true}
>
  <article class="home">

    <!-- ── §01 Hero ──────────────────────────────────────────── -->
    <section class="home__hero">
      <div class="home__hero-inner container--wide">

        <div class="home__hero-text">
          <p class="label home__location">Newport Beach, California</p>
          <h1 class="home__name">Christian<br>Kameir</h1>
          <p class="home__tagline">Reality does not have an advertising budget.</p>

          <div class="home__bio prose">
            <p>
              Advisor, author, and speaker based in Newport Beach, California.
              Thirty years at the intersection of capital markets, technology, and law —
              helping capital-intensive companies from German-speaking countries establish
              US operations, speaking at conferences on AI, blockchain, and the future of
              money, and publishing practical guides for practitioners navigating AI risk.
            </p>
          </div>

          <div class="home__cta">
            <a href="/advisory" class="btn btn--primary">Advisory</a>
            <a href="/speaking" class="btn btn--outline">Speaking</a>
            <a href="/ai-ethics" class="home__cta-ghost">Get the AI Ethics eBook →</a>
          </div>
        </div>

        <div class="home__hero-photo">
          <img
            src="/images/christian-kameir.jpg"
            alt="Christian Kameir"
            width="460"
            height="575"
            class="home__photo"
            loading="eager"
            fetchpriority="high"
          />
        </div>

      </div>
    </section>

    <!-- ── §02 Credibility strip ──────────────────────────────── -->
    <div class="home__cred">
      <div class="container--wide home__cred-inner">

        <div class="home__cred-item">
          <span class="home__cred-stat">30 years</span>
          <span class="home__cred-desc">At the intersection of capital markets,<br>technology, and law</span>
        </div>

        <div class="home__cred-rule" aria-hidden="true"></div>

        <div class="home__cred-item">
          <span class="home__cred-stat">Harvard</span>
          <span class="home__cred-desc">Guest lecturer on fintech<br>and central bank digital currencies</span>
        </div>

        <div class="home__cred-rule" aria-hidden="true"></div>

        <div class="home__cred-item">
          <span class="home__cred-stat">Forbes</span>
          <span class="home__cred-desc">Contributor on technology,<br>capital, and financial innovation</span>
        </div>

        <div class="home__cred-rule" aria-hidden="true"></div>

        <div class="home__cred-item">
          <span class="home__cred-stat">DIF Chair</span>
          <span class="home__cred-desc">Banking &amp; Finance Special<br>Interest Group</span>
        </div>

      </div>
    </div>

    <!-- ── §03 Three pillars ───────────────────────────────────── -->
    <section class="home__pillars">
      <div class="container--wide home__pillars-inner">

        <div class="home__pillar">
          <p class="label home__pillar-label">Advisory</p>
          <h2 class="home__pillar-title">German companies<br>entering the US market</h2>
          <p class="home__pillar-desc">
            Market entry, federal and state incentives, and private capital for
            capital-intensive industrials, energy developers, and advanced manufacturers.
            Retained engagements from $18,000/month.
          </p>
          <a href="/advisory" class="home__pillar-link">Learn more →</a>
        </div>

        <div class="home__pillar-rule" aria-hidden="true"></div>

        <div class="home__pillar">
          <p class="label home__pillar-label">Speaking</p>
          <h2 class="home__pillar-title">Keynotes on AI,<br>blockchain &amp; money</h2>
          <p class="home__pillar-desc">
            Practitioner-level sessions for conferences, executive events, and industry
            summits. Topics span AI ethics, decentralized finance, and the future of
            monetary systems. From $1,950 virtual.
          </p>
          <a href="/speaking" class="home__pillar-link">Book a keynote →</a>
        </div>

        <div class="home__pillar-rule" aria-hidden="true"></div>

        <div class="home__pillar">
          <p class="label home__pillar-label">Books</p>
          <h2 class="home__pillar-title">Practical AI ethics<br>guides for practitioners</h2>
          <p class="home__pillar-desc">
            Operational playbooks for the real risks AI creates — not academic theory,
            not vendor brochures. First: law firms. Second coming soon: money and AI.
          </p>
          <a href="/ai-ethics" class="home__pillar-link">Get the eBook →</a>
        </div>

      </div>
    </section>

    <!-- ── §04 eBook spotlight ────────────────────────────────── -->
    <section class="home__book">
      <div class="container--wide home__book-inner">

        <div class="home__book-cover" aria-hidden="true">
          <p class="home__book-cover-title">Ethics Safe AI Use<br>for Law Firms</p>
          <p class="home__book-cover-sub">A Litigation Risk Reduction Playbook<br>for Personal Injury Firms</p>
          <p class="home__book-cover-author">Christian Kameir</p>
          <p class="home__book-cover-pub">Decentralized Publishing LLC</p>
        </div>

        <div class="home__book-text">
          <p class="label">New release</p>
          <h2 class="home__book-title">The AI mistakes costing PI&nbsp;firms their fees — and the protocols that prevent them.</h2>
          <ul class="home__book-points" role="list">
            <li>ABA Formal Opinion 512 mapped to your firm's workflow</li>
            <li>47-point Red/Yellow/Green audit checklist included</li>
            <li>Disclosure language for N.D.&nbsp;Cal. and C.D.&nbsp;Cal. filings</li>
            <li>12-month updates as the sanctions record grows</li>
          </ul>
          <div class="home__book-cta">
            <a href="https://kameir.lemonsqueezy.com/checkout/buy/2b55aecd-d496-4892-9ec5-32559edb5662" class="btn btn--primary">Get the Firm License — $199</a>
            <a href="/ai-ethics/lead-magnet" class="btn btn--outline">Free: 47-Point AI Checklist</a>
          </div>
          <p class="home__book-single">
            Single-user license: <a href="https://kameir.lemonsqueezy.com/checkout/buy/b0db44f3-58c3-4a76-adce-9f26ecfe6bcf">$49</a>
            &thinsp;·&thinsp;
            <a href="/ai-ethics">Full details →</a>
          </p>
        </div>

      </div>
    </section>

    <!-- ── §05 Speaking signal ────────────────────────────────── -->
    <section class="home__speaking">
      <div class="container--wide home__speaking-inner">

        <div class="home__speaking-text">
          <p class="label">Speaking</p>
          <h2 class="home__speaking-title">The room needs a different frame<br>on the money question.</h2>
          <p class="home__speaking-desc">
            Thirty years across capital markets, technology, and law — including active
            roles in CBDC development, decentralized identity infrastructure, and venture
            investing across three continents. Kameir does not speak from the sidelines.
          </p>
          <p class="home__speaking-fees">US keynotes from $6,950 · Virtual from $1,950</p>
          <a href="/speaking" class="btn btn--outline">Check availability</a>
        </div>

        <div class="home__speaking-engagements">
          <p class="label home__eng-label">Selected past engagements</p>
          <ol class="home__eng-list" role="list">
            <li class="home__eng-item">
              <a href="https://youtu.be/0-Lw9zp55Jk" target="_blank" rel="noopener" class="home__eng-link">
                <span class="home__eng-name">IDEAS Conference</span>
                <span class="home__eng-topic">Keynote — The Future of Fintech</span>
              </a>
            </li>
            <li class="home__eng-item">
              <a href="https://youtu.be/brzLTA2q6qs" target="_blank" rel="noopener" class="home__eng-link">
                <span class="home__eng-name">OnChain Conference</span>
                <span class="home__eng-topic">Keynote — Blockchain Investing</span>
              </a>
            </li>
            <li class="home__eng-item">
              <a href="https://youtu.be/F3two0v84JI" target="_blank" rel="noopener" class="home__eng-link">
                <span class="home__eng-name">Web3 Conference</span>
                <span class="home__eng-topic">Keynote</span>
              </a>
            </li>
            <li class="home__eng-item">
              <a href="https://youtu.be/neV9Mz6oOkk" target="_blank" rel="noopener" class="home__eng-link">
                <span class="home__eng-name">Expert Panel</span>
                <span class="home__eng-topic">Alternative Funding</span>
              </a>
            </li>
          </ol>
          <a href="/speaking" class="home__speaking-all">All topics and past engagements →</a>
        </div>

      </div>
    </section>

    <!-- ── §06 Recent Writing ──────────────────────────────────── -->
    {recentPosts.length > 0 && (
      <section class="home__writing">
        <div class="container--wide home__writing-inner">
          <div class="home__writing-header">
            <div>
              <p class="label">Writing</p>
              <p class="home__writing-intro">Essays on money, capital, technology, and the institutions that govern them.</p>
            </div>
            <a href="/writing" class="home__writing-all">All essays →</a>
          </div>
          <ol class="home__writing-list" role="list">
            {recentPosts.map(post => (
              <li class="home__writing-item">
                <a href={`/writing/${post.slug}`} class="home__writing-link">
                  <time class="label home__writing-date" datetime={post.data.publishedAt.toISOString()}>
                    {fmt.format(post.data.publishedAt)}
                  </time>
                  <span class="home__writing-title">{post.data.title}</span>
                </a>
              </li>
            ))}
          </ol>
        </div>
      </section>
    )}

    <!-- ── §07 Advisory close ─────────────────────────────────── -->
    <section class="home__close">
      <div class="container--wide home__close-inner">
        <div class="home__close-text">
          <p class="label">Advisory practice</p>
          <h2 class="home__close-title">Independent advisory for German-speaking companies entering the US market.</h2>
          <p class="home__close-desc">
            Retained engagements from $18,000/month. The roster is deliberately
            small — no more than a handful of clients at any time. Currently accepting inquiries.
          </p>
        </div>
        <a href="/contact" class="btn btn--primary home__close-btn">Request a call</a>
      </div>
    </section>

  </article>
</Base>
