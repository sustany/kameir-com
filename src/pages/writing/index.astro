---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';

const posts = (await getCollection('writing', ({ data }) => !data.draft))
  .sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime());

const fmt = new Intl.DateTimeFormat('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<Base
  title="Writing"
  description="Essays and short takes by Christian Kameir on capital, technology, and ideas."
>
  <article class="writing">
    <div class="container">

      <header class="writing__header">
        <p class="label">Writing</p>
        <h1 class="writing__title">Notes &amp; Essays</h1>
        <p class="writing__intro">
          Observations on capital, technology, and the forces shaping both.
        </p>
      </header>

      <hr class="rule" />

      {posts.length === 0 ? (
        <p class="writing__empty">Nothing published yet. Check back soon.</p>
      ) : (
        <ol class="writing__list" role="list">
          {posts.map(post => (
            <li class="writing__item">
              <a href={`/writing/${post.slug}`} class="writing__item-link">
                <time class="label writing__date" datetime={post.data.publishedAt.toISOString()}>
                  {fmt.format(post.data.publishedAt)}
                </time>
                <div class="writing__item-body">
                  <h2 class="writing__item-title">{post.data.title}</h2>
                  <p class="writing__item-desc">{post.data.description}</p>
                </div>
                <span class="writing__item-arrow" aria-hidden="true">→</span>
              </a>
            </li>
          ))}
        </ol>
      )}

    </div>
  </article>
</Base>

<style>
.writing__header {
  padding-top: 4rem;
  padding-bottom: var(--space-l);
}

.writing__title {
  font-family: var(--font-display);
  font-size: clamp(2.5rem, 6vw, 3.75rem);
  font-weight: 700;
  line-height: 1.1;
  letter-spacing: -0.02em;
  margin-top: 0.75rem;
}

.writing__intro {
  font-size: 1.05rem;
  color: var(--text-muted);
  max-width: 480px;
  line-height: 1.7;
  margin-top: 1rem;
}

.writing__empty {
  color: var(--text-muted);
  padding-block: var(--space-l);
}

/* ── List ──────────────────────────────────────────── */
.writing__list {
  list-style: none;
  padding: 0;
  margin: 0;
  padding-bottom: var(--space-xl);
}

.writing__item + .writing__item {
  border-top: 1px solid var(--rule);
}

.writing__item-link {
  display: grid;
  grid-template-columns: 160px 1fr auto;
  align-items: baseline;
  gap: 1.5rem;
  padding-block: var(--space-m);
  text-decoration: none;
  color: inherit;
  transition: color 0.15s;
  border-left: 2px solid transparent;
  padding-left: 0;
  margin-left: -2px;
  transition: border-color 0.2s, color 0.15s;
}
.writing__item-link:hover {
  color: var(--accent);
  border-left-color: var(--accent);
  padding-left: 1rem;
}

.writing__date {
  display: block;
  padding-top: 0.15rem;
}

.writing__item-body {
  min-width: 0;
}

.writing__item-title {
  font-family: var(--font-display);
  font-size: clamp(1.15rem, 2.5vw, 1.4rem);
  font-weight: 700;
  line-height: 1.2;
  letter-spacing: -0.01em;
  color: var(--text);
  margin-bottom: 0.4rem;
}

.writing__item-desc {
  font-size: 0.9rem;
  color: var(--text-muted);
  line-height: 1.6;
}

.writing__item-arrow {
  font-family: var(--font-ui);
  font-size: 1rem;
  color: var(--text-muted);
  transition: color 0.15s, transform 0.15s;
  display: inline-block;
}
.writing__item-link:hover .writing__item-arrow {
  color: var(--accent);
  transform: translateX(3px);
}

/* ── Responsive ─────────────────────────────────────── */
@media (max-width: 640px) {
  .writing__item-link {
    grid-template-columns: 1fr;
    gap: 0.4rem;
    padding-left: 0;
    margin-left: 0;
    border-left: none;
    border-top: 2px solid transparent;
    transition: border-color 0.2s, color 0.15s;
  }
  .writing__item-link:hover {
    padding-left: 0;
    border-left: none;
    border-top-color: var(--accent);
  }
  .writing__item-arrow { display: none; }
}
</style>
