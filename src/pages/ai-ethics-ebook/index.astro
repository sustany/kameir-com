---
import Base from '../../layouts/Base.astro';

const lsCheckout = "https://kameir.lemonsqueezy.com/checkout/buy/d48ff7aa-63b0-4499-9d02-56bf965d2347";

const bookSchema = {
  "@context": "https://schema.org",
  "@type": "Book",
  "name": "Ethics-Safe AI Use for Law Firms",
  "author": {
    "@type": "Person",
    "name": "Christian Kameir",
    "url": "https://kameir.com/about"
  },
  "publisher": {
    "@type": "Organization",
    "name": "Decentralized Publishing LLC"
  },
  "bookFormat": "https://schema.org/EBook",
  "inLanguage": "en",
  "genre": "Legal Ethics",
  "about": "AI ethics compliance framework for law firms — ABA Model Rules, AI hallucination taxonomy, the Mata Protocol, and the Five Artifacts test.",
  "url": "https://kameir.com/ai-ethics-ebook",
  "offers": {
    "@type": "Offer",
    "price": "49",
    "priceCurrency": "USD",
    "availability": "https://schema.org/InStock",
    "url": lsCheckout
  }
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://kameir.com" },
    { "@type": "ListItem", "position": 2, "name": "Ethics-Safe AI Use for Law Firms", "item": "https://kameir.com/ai-ethics-ebook" }
  ]
};
---

<Base
  title="Ethics-Safe AI Use for Law Firms — eBook | Christian Kameir"
  description="The practitioner's framework for AI compliance in legal practice. ABA Model Rules mapped to AI failure modes, the Mata Protocol, the Five Artifacts test, and a hallucination taxonomy drawn from 1,356 documented court cases. $49."
  canonicalUrl="https://kameir.com/ai-ethics-ebook"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(bookSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  </Fragment>

  <main class="ebook">

    <!-- Hero -->
    <section class="ebook-hero">
      <div class="ebook-hero__inner">
        <div class="ebook-hero__text">
          <p class="label">eBook · Immediate Download</p>
          <h1 class="ebook-hero__h1">Ethics-Safe AI Use<br>for Law Firms</h1>
          <p class="ebook-hero__author">by Christian Kameir</p>
          <p class="ebook-hero__lead">
            The only AI ethics framework built entirely from the documented sanctions record — 1,356 cases where AI failed in legal practice, analyzed through the seven ABA Model Rules that actually bite.
          </p>

          <ul class="ebook-hero__bullets">
            <li>The seven Model Rules implicated by AI failures — with case citations for each</li>
            <li>The Mata Protocol: a step-by-step verification process for AI-generated research</li>
            <li>The Five Artifacts test — what your firm must document to demonstrate reasonable AI oversight</li>
            <li>A five-category hallucination taxonomy and the detection technique for each type</li>
            <li>A firm-level AI use policy template based on Op. 512 and the sanctions record</li>
          </ul>

          <div class="ebook-hero__cta">
            <div class="ebook-price-block">
              <span class="ebook-price__amount">$49</span>
              <span class="ebook-price__label">One-time · Immediate access · PDF + EPUB</span>
            </div>
            <a href={lsCheckout} class="btn btn--primary btn--lg" rel="noopener">
              Get the eBook →
            </a>
            <p class="ebook-hero__guarantee">30-day refund guarantee. No questions.</p>
          </div>
        </div>

        <div class="ebook-hero__cover">
          <picture>
            <source srcset="/images/book-cover_ai.webp" type="image/webp" />
            <img src="/images/book-cover_ai.jpg" alt="Ethics-Safe AI Use for Law Firms — book cover"
              width="380" height="494" loading="eager" fetchpriority="high" class="ebook-cover__img" />
          </picture>
          <p class="ebook-cover__caption">Published by Decentralized Publishing LLC</p>
        </div>
      </div>
    </section>

    <!-- Credibility strip -->
    <div class="ebook-strip">
      <div class="ebook-strip__inner">
        <span>Forbes contributor</span>
        <span class="ebook-strip__dot">·</span>
        <span>Harvard Extension School lecturer</span>
        <span class="ebook-strip__dot">·</span>
        <span>1,356 cases documented</span>
        <span class="ebook-strip__dot">·</span>
        <span>DIF Chair</span>
      </div>
    </div>

    <!-- What problem this solves -->
    <section class="ebook-section">
      <div class="ebook-section__inner">
        <h2>Why This Book Exists</h2>
        <div class="ebook-prose">
          <p>
            Every AI ethics resource available to attorneys in 2024 was written before the sanctions record existed. The guidance was theoretical — built on what might go wrong, not on what already had.
          </p>
          <p>
            This book is different. It was written after documenting 1,356 cases where generative AI produced fabricated citations, invented quotes, misrepresented statutes, or otherwise failed in real court proceedings — and after mapping each failure to the Model Rule it implicated, the verification step that would have caught it, and the firm documentation that would have mitigated the sanction.
          </p>
          <p>
            The result is a framework that is grounded in what courts have actually penalized, not in what bar associations theorize they might penalize. If you are going to use AI in legal practice — or if you supervise attorneys who do — this is the framework you need.
          </p>
        </div>
      </div>
    </section>

    <!-- Chapter breakdown -->
    <section class="ebook-section ebook-section--alt">
      <div class="ebook-section__inner">
        <p class="label">What the book covers</p>
        <div class="ebook-chapters">
          <div class="ebook-chapter">
            <span class="ebook-chapter__num">01</span>
            <div>
              <h3>ABA Opinion 512 and What It Actually Requires</h3>
              <p>Op. 512 is frequently cited and rarely read in full. This chapter maps the opinion's specific requirements against the AI tools currently in use in legal practice and identifies the gap between what the opinion requires and what most firms are doing.</p>
            </div>
          </div>
          <div class="ebook-chapter">
            <span class="ebook-chapter__num">02</span>
            <div>
              <h3>The Seven Model Rules That Bite</h3>
              <p>Competence (1.1), Supervision (5.1 / 5.3), Candor (3.3), Confidentiality (1.6), Fees (1.5), Advertising (7.1), and Unauthorized Practice (5.5) — each mapped to the specific AI failure modes that have triggered sanctions, with citations to the cases that defined the exposure.</p>
            </div>
          </div>
          <div class="ebook-chapter">
            <span class="ebook-chapter__num">03</span>
            <div>
              <h3>The Five-Category Hallucination Taxonomy</h3>
              <p>Not all AI failures are the same. This chapter categorizes the hallucination types documented in 1,356 cases — citation fabrication, quote fabrication, statute misrepresentation, procedural fiction, and party misattribution — and identifies the specific detection technique that catches each type.</p>
            </div>
          </div>
          <div class="ebook-chapter">
            <span class="ebook-chapter__num">04</span>
            <div>
              <h3>The Mata Protocol</h3>
              <p>A step-by-step verification process for AI-generated legal research, derived from the specific failures documented in the sanctions record. Designed to be implemented as a firm procedure, not as a personal checklist — with assigned responsibility at each step.</p>
            </div>
          </div>
          <div class="ebook-chapter">
            <span class="ebook-chapter__num">05</span>
            <div>
              <h3>The Five Artifacts Test</h3>
              <p>What your firm must maintain to demonstrate reasonable AI oversight in a disciplinary proceeding — the five documents, logs, and records that distinguish supervised AI use from unsupervised use in the eyes of a bar investigator.</p>
            </div>
          </div>
          <div class="ebook-chapter">
            <span class="ebook-chapter__num">06</span>
            <div>
              <h3>Writing Your Firm's AI Use Policy</h3>
              <p>A template AI use policy grounded in Op. 512, the seven Model Rules, and the sanctions record — with annotations explaining the reasoning behind each provision and guidance on adapting it to your jurisdiction's specific requirements.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Who it's for -->
    <section class="ebook-section">
      <div class="ebook-section__inner">
        <h2>Who This Is For</h2>
        <div class="ebook-for__grid">
          <div class="ebook-for__item">
            <h3>Partners and Firm Leaders</h3>
            <p>The supervisory exposure under Rules 5.1 and 5.3 applies to you directly — whether or not you personally use AI. This book tells you what reasonable supervision of AI use looks like and what documentation you need to demonstrate it.</p>
          </div>
          <div class="ebook-for__item">
            <h3>Associates and Staff Attorneys</h3>
            <p>Competence under Rule 1.1 now includes understanding the limitations of the tools you use. If you use AI to draft, research, or review, you need a verification protocol. This book gives you one.</p>
          </div>
          <div class="ebook-for__item">
            <h3>General Counsel and In-House Teams</h3>
            <p>The same framework applies in corporate legal departments. The AI governance questions your legal ops team is asking — and the board-level AI policy questions your GC is being asked to answer — are addressed directly.</p>
          </div>
          <div class="ebook-for__item">
            <h3>Legal Technology and Compliance Staff</h3>
            <p>If you are selecting, deploying, or auditing AI tools in a legal environment, this book provides the framework for evaluating those tools against the specific failure modes that have already produced sanctions.</p>
          </div>
        </div>
      </div>
    </section>


    <!-- ── Free chapter opt-in ──────────────────────────────────────── -->
    <section class="ebook-optin" id="free-chapter">
      <div class="ebook-optin__inner">
        <div class="ebook-optin__text">
          <p class="label">Free chapter</p>
          <h2 class="ebook-optin__h">Not ready to buy? Start with Chapter 1 free.</h2>
          <p class="ebook-optin__sub">The Sanctions Record — the full five-category hallucination taxonomy with annotated case examples. No purchase required.</p>
        </div>
        <form class="ebook-optin__form" id="ebookOptInForm" action="https://formspree.io/f/xjgjawba" method="POST">
          <input type="hidden" name="source" value="ebook-free-chapter" />
          <div class="ebook-optin__fields">
            <input type="text" name="name" placeholder="Your name" required autocomplete="name" />
            <input type="email" name="email" placeholder="Work email" required autocomplete="email" />
          </div>
          <button type="submit" class="btn btn--primary">Send me Chapter 1 →</button>
          <p class="ebook-optin__note" id="ebookOptInNote" style="display:none;"></p>
        </form>
      </div>
    </section>
    <script>
      (function() {
        var form = document.getElementById('ebookOptInForm');
        if (!form) return;
        form.addEventListener('submit', async function(e) {
          e.preventDefault();
          var btn = form.querySelector('button[type="submit"]');
          btn.textContent = 'Sending…'; btn.disabled = true;
          try {
            var res = await fetch(form.action, { method: 'POST', body: new FormData(form), headers: { Accept: 'application/json' } });
            if (res.ok) {
              form.innerHTML = '<p style="font-size:1rem;font-weight:600;color:var(--accent);">✓ Chapter 1 is on its way — check your inbox.</p>';
            } else {
              btn.textContent = 'Send me Chapter 1 →'; btn.disabled = false;
              var note = document.getElementById('ebookOptInNote');
              note.textContent = 'Something went wrong. Try again or email chris@sustany.co.';
              note.style.display = 'block';
            }
          } catch(err) {
            btn.textContent = 'Send me Chapter 1 →'; btn.disabled = false;
            var note = document.getElementById('ebookOptInNote');
            note.textContent = 'Network error. Please try again.';
            note.style.display = 'block';
          }
        });
      })();
    </script>

    <!-- CTA block -->
    <section class="ebook-cta-block">
      <div class="ebook-cta-block__inner">
        <h2>Get the Framework</h2>
        <p>Immediate download. PDF and EPUB. 30-day refund guarantee.</p>
        <div class="ebook-cta-block__price">
          <span class="ebook-price__amount">$49</span>
        </div>
        <a href={lsCheckout} class="btn btn--primary btn--lg" rel="noopener">
          Get Ethics-Safe AI Use for Law Firms →
        </a>
        <div class="ebook-cta-block__also">
          <p>Prefer live training?</p>
          <div class="ebook-cta-block__also-links">
            <a href="/ai-ethics-training">Online self-paced training ($49 individual / $199 firm)</a>
            <a href="/ai-ethics-training/newport-beach-june-2026">Live Newport Beach intensive — June 27 ($399 early bird)</a>
          </div>
        </div>
      </div>
    </section>

    <!-- About author -->
    <section class="ebook-section">
      <div class="ebook-section__inner ebook-author__inner">
        <div class="ebook-author__photo">
          <picture>
            <source srcset="/images/christian-kameir.webp" type="image/webp" />
            <img src="/images/christian-kameir.jpg" alt="Christian Kameir" width="160" height="160" loading="lazy" />
          </picture>
        </div>
        <div class="ebook-author__bio">
          <p class="label">About the author</p>
          <h2>Christian Kameir</h2>
          <p>Christian documented 1,356 AI hallucination cases from real court proceedings — the largest public dataset of AI failures in legal practice. He lectures at Harvard Extension School, contributes to Forbes, and chairs the Decentralized Identity Foundation. He has practiced at the intersection of law and technology since the 1990s.</p>
          <div class="ebook-author__links">
            <a href="/about">Full bio</a>
            <a href="/AI-legal-research">View the case database</a>
            <a href="/writing">Articles and commentary</a>
          </div>
        </div>
      </div>
    </section>

  </main>

  <style>
    :root {
      --eb-accent: #1B3A5C;
      --eb-gold: #C8892A;
      --eb-surface: #f8f9fa;
      --eb-border: #e2e8f0;
      --eb-text: #1a202c;
      --eb-muted: #64748b;
      --eb-radius: 8px;
      --eb-max: 900px;
    }

    /* Hero */
    .ebook-hero { padding: 4.5rem 1.5rem 3.5rem; }
    .ebook-hero__inner { max-width: 1040px; margin: 0 auto; display: grid; grid-template-columns: 1fr 340px; gap: 4rem; align-items: start; }
    .ebook-hero__text .label { margin-bottom: 1rem; }
    .ebook-hero__h1 { font-family: 'Playfair Display', Georgia, serif; font-size: clamp(2rem, 5vw, 3.25rem); font-weight: 700; line-height: 1.1; color: var(--eb-accent); margin: 0 0 0.35rem; }
    .ebook-hero__author { font-family: 'Lora', Georgia, serif; font-style: italic; font-size: 1.05rem; color: var(--eb-muted); margin: 0 0 1.25rem; }
    .ebook-hero__lead { font-size: 1.05rem; line-height: 1.7; color: var(--eb-text); margin-bottom: 1.5rem; }
    .ebook-hero__bullets { list-style: none; padding: 0; margin: 0 0 2rem; display: flex; flex-direction: column; gap: 0.6rem; }
    .ebook-hero__bullets li { font-size: 0.92rem; line-height: 1.55; color: var(--eb-text); padding-left: 1.4rem; position: relative; }
    .ebook-hero__bullets li::before { content: '✓'; position: absolute; left: 0; color: var(--eb-gold); font-weight: 700; }
    .ebook-hero__cta { display: flex; flex-direction: column; align-items: flex-start; gap: 0.6rem; }
    .ebook-price-block { display: flex; flex-direction: column; gap: 0.1rem; }
    .ebook-price__amount { font-size: 2.5rem; font-weight: 700; color: var(--eb-accent); line-height: 1; }
    .ebook-price__label { font-size: 0.82rem; color: var(--eb-muted); }
    .ebook-hero__guarantee { font-size: 0.8rem; color: var(--eb-muted); margin: 0; }

    /* Cover */
    .ebook-hero__cover { display: flex; flex-direction: column; align-items: center; gap: 0.75rem; position: sticky; top: 2rem; }
    .ebook-cover__img { width: 100%; border-radius: var(--eb-radius); box-shadow: 0 8px 32px rgba(27,58,92,0.18); }
    .ebook-cover__caption { font-size: 0.75rem; color: var(--eb-muted); text-align: center; }

    /* Credibility strip */
    .ebook-strip { background: var(--eb-accent); color: #fff; padding: 0.85rem 1.5rem; }
    .ebook-strip__inner { max-width: 1040px; margin: 0 auto; display: flex; flex-wrap: wrap; gap: 0.5rem 1.25rem; align-items: center; justify-content: center; font-size: 0.85rem; opacity: 0.9; }
    .ebook-strip__dot { opacity: 0.4; }

    /* Sections */
    .ebook-section { padding: 4rem 1.5rem; }
    .ebook-section--alt { background: var(--eb-surface); }
    .ebook-section__inner { max-width: var(--eb-max); margin: 0 auto; }
    .ebook-section h2 { font-family: 'Playfair Display', Georgia, serif; font-size: clamp(1.5rem, 3vw, 2.1rem); color: var(--eb-accent); margin: 0 0 1.5rem; }
    .ebook-section .label { margin-bottom: 1.5rem; }
    .ebook-prose p { font-size: 1rem; line-height: 1.8; color: var(--eb-text); margin-bottom: 1.25em; max-width: 660px; }

    /* Chapters */
    .ebook-chapters { display: flex; flex-direction: column; gap: 0; }
    .ebook-chapter { display: grid; grid-template-columns: 3rem 1fr; gap: 1.25rem; padding: 1.5rem 0; border-bottom: 1px solid var(--eb-border); align-items: start; }
    .ebook-chapter:last-child { border-bottom: none; }
    .ebook-chapter__num { font-size: 0.75rem; font-weight: 700; color: var(--eb-accent); background: rgba(27,58,92,0.08); border-radius: 4px; padding: 0.3rem 0.4rem; text-align: center; margin-top: 0.2rem; font-family: 'Courier New', monospace; }
    .ebook-chapter h3 { grid-column: 2; font-family: 'Playfair Display', Georgia, serif; font-size: 1.05rem; color: var(--eb-text); margin: 0 0 0.5rem; }
    .ebook-chapter p { grid-column: 2; font-size: 0.88rem; line-height: 1.7; color: var(--eb-muted); margin: 0; }

    /* For grid */
    .ebook-for__grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: 1.75rem; }
    .ebook-for__item { border: 1px solid var(--eb-border); border-radius: var(--eb-radius); padding: 1.5rem; }
    .ebook-for__item h3 { font-family: 'Playfair Display', Georgia, serif; font-size: 1rem; color: var(--eb-accent); margin: 0 0 0.6rem; }
    .ebook-for__item p { font-size: 0.88rem; line-height: 1.7; color: var(--eb-muted); margin: 0; }

    /* CTA block */
    .ebook-cta-block { background: var(--eb-accent); color: #fff; padding: 4rem 1.5rem; text-align: center; }
    .ebook-cta-block__inner { max-width: 560px; margin: 0 auto; }
    .ebook-cta-block h2 { font-family: 'Playfair Display', Georgia, serif; font-size: 2rem; color: #fff; margin: 0 0 0.5rem; }
    .ebook-cta-block > .ebook-cta-block__inner > p { color: rgba(255,255,255,0.8); margin-bottom: 1.25rem; font-size: 0.95rem; }
    .ebook-cta-block__price { margin-bottom: 1.25rem; }
    .ebook-cta-block .ebook-price__amount { color: #fff; font-size: 3rem; }
    .ebook-cta-block__also { margin-top: 2.5rem; border-top: 1px solid rgba(255,255,255,0.2); padding-top: 1.5rem; }
    .ebook-cta-block__also > p { color: rgba(255,255,255,0.65); font-size: 0.85rem; margin-bottom: 0.75rem; }
    .ebook-cta-block__also-links { display: flex; flex-direction: column; gap: 0.4rem; }
    .ebook-cta-block__also-links a { color: rgba(255,255,255,0.8); font-size: 0.85rem; text-decoration: underline; text-underline-offset: 2px; }
    .ebook-cta-block__also-links a:hover { color: #fff; }

    /* Author */
    .ebook-author__inner { display: grid; grid-template-columns: 160px 1fr; gap: 2.5rem; align-items: start; }
    .ebook-author__photo img { width: 160px; height: 160px; object-fit: cover; border-radius: var(--eb-radius); border: 2px solid var(--eb-border); }
    .ebook-author__bio .label { margin-bottom: 0.5rem; }
    .ebook-author__bio h2 { font-family: 'Playfair Display', Georgia, serif; font-size: 1.5rem; color: var(--eb-accent); margin: 0 0 0.25rem; }
    .ebook-author__bio p { font-size: 0.95rem; line-height: 1.75; color: var(--eb-text); margin: 0.75rem 0 1rem; }
    .ebook-author__links { display: flex; gap: 1.25rem; flex-wrap: wrap; }
    .ebook-author__links a { color: var(--eb-accent); font-size: 0.88rem; font-weight: 600; text-decoration: none; }
    .ebook-author__links a:hover { text-decoration: underline; }

    /* Buttons */
    .btn { display: inline-block; padding: 0.75rem 1.75rem; border-radius: var(--eb-radius); font-weight: 600; text-decoration: none; font-size: 1rem; transition: background 0.18s, transform 0.12s; }
    .btn--primary { background: var(--eb-gold); color: #fff; }
    .btn--primary:hover { background: #a97220; transform: translateY(-1px); }
    .btn--lg { padding: 0.875rem 2.25rem; font-size: 1.05rem; }

    @media (max-width: 740px) {
      .ebook-hero__inner { grid-template-columns: 1fr; gap: 2.5rem; }
      .ebook-hero__cover { position: static; order: -1; }
      .ebook-cover__img { max-width: 240px; }
      .ebook-author__inner { grid-template-columns: 1fr; }
    }
  
/* Lead magnet opt-in */
.ebook-optin { background: var(--bg-subtle); padding: var(--space-xl) 0; }
.ebook-optin__inner { max-width: 900px; margin: 0 auto; padding: 0 var(--space-md); display: grid; grid-template-columns: 1fr 1fr; gap: 3rem; align-items: center; }
.ebook-optin__h { font-family: var(--font-display); font-size: 1.4rem; margin: 0.25rem 0 0.5rem; }
.ebook-optin__sub { color: var(--text-muted); font-size: 0.95rem; margin: 0; }
.ebook-optin__form { display: flex; flex-direction: column; gap: 0.75rem; }
.ebook-optin__fields { display: flex; flex-direction: column; gap: 0.5rem; }
.ebook-optin__fields input { padding: 0.65rem 0.9rem; border: 1px solid var(--border); border-radius: 3px; font-size: 0.95rem; background: var(--bg-base); color: var(--text); width: 100%; box-sizing: border-box; }
.ebook-optin__note { font-size: 0.85rem; color: var(--text-muted); margin: 0; }
@media (max-width: 700px) { .ebook-optin__inner { grid-template-columns: 1fr; } }

</style>
</Base>
