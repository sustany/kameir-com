      padding: 1.1rem 0;
      font-weight: 600;
      font-size: 1rem;
      color: var(--nb-text);
      list-style: none;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }
    .nb-faq__item summary::after { content: '+'; font-size: 1.25rem; color: var(--nb-accent); }
    .nb-faq__item[open] summary::after { content: '−'; }
    .nb-faq__item p { padding: 0 0 1rem; margin: 0; font-size: 0.95rem; color: var(--nb-muted); line-height: 1.65; }

    /* ── Online fallback ── */
