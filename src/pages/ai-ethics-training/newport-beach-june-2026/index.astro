      background: var(--nb-bg-alt, #f5f5f5);
      border-color: var(--nb-border);
    }
    .nb-cd-box--neutral .nb-cd-n,
    .nb-cd-box--neutral .nb-cd-l { color: var(--nb-muted); }

  </style>
</Base>

<script>
(function() {
  var EARLY_BIRD = new Date('2026-05-29T23:59:00-07:00');
  var EVENT_DATE = new Date('2026-06-27T09:00:00-07:00');

  function pad(n) { return String(Math.floor(n)).padStart(2, '0'); }

  function tick() {
    var now = new Date();
    var diff = EARLY_BIRD - now;
    var isExpired = diff <= 0;

    // Bar countdown
    var barEl = document.getElementById('nb-bar-cd');
    // Strip boxes
    var dEl = document.getElementById('nb-cd-d');
    var hEl = document.getElementById('nb-cd-h');
    var mEl = document.getElementById('nb-cd-m');
    var lblEl = document.getElementById('nb-cd-label');
    // Registration card countdown
    var regEl = document.getElementById('nb-reg-days');
    var regCard = document.getElementById('nb-reg-cd');

    if (!isExpired) {
      var days = Math.floor(diff / 86400000);
      var hours = Math.floor((diff % 86400000) / 3600000);
      var mins = Math.floor((diff % 3600000) / 60000);

      if (barEl) {
        barEl.textContent = days > 0
          ? days + 'd ' + pad(hours) + 'h ' + pad(mins) + 'm'
          : pad(hours) + 'h ' + pad(mins) + 'm';
      }
      if (dEl) dEl.textContent = days;
      if (hEl) hEl.textContent = pad(hours);
      if (mEl) mEl.textContent = pad(mins);
      if (lblEl) lblEl.textContent = 'left at $399 · price rises May 30';
      if (regEl) {
        regEl.textContent = days > 0
          ? days + ' day' + (days === 1 ? '' : 's')
          : pad(hours) + 'h ' + pad(mins) + 'm';
      }
    } else {
      // Post-deadline: switch to event countdown in neutral style
      var evDiff = Math.max(0, EVENT_DATE - now);
      var evDays = Math.floor(evDiff / 86400000);

      if (barEl) barEl.textContent = '';

      // Neutralise strip boxes
      var boxes = document.querySelectorAll('.nb-cd-box');
      boxes.forEach(function(b) { b.classList.add('nb-cd-box--neutral'); });

      if (dEl) dEl.textContent = evDays;
      if (hEl) hEl.textContent = pad(Math.floor((evDiff % 86400000) / 3600000));
      if (mEl) mEl.textContent = pad(Math.floor((evDiff % 3600000) / 60000));
      if (lblEl) {
        lblEl.textContent = 'until the event · June 27, Newport Beach';
        lblEl.classList.add('nb-cd-label--neutral');
      }
      if (regCard) regCard.style.display = 'none';
    }
  }

  tick();
  setInterval(tick, 30000);
})();
</script>
