---
import Base from '../layouts/Base.astro';

const modules = [
  {
    number: 1,
    title: 'PLACEHOLDER 芒聙聰 AI Ethics',
    duration: '~60 min',
    description: 'Foundational principles of AI ethics in legal practice. Covers the professional responsibility framework attorneys must understand before deploying AI tools in client matters.',
  },
  {
    number: 2,
    title: 'AI Risk & Candor',
    duration: '~60 min',
    description: 'How AI hallucinations create Rule 3.3 candor violations 芒聙聰 with examples drawn from sanctioned cases. Includes the verification protocol courts now expect.',
    featured: true,
  },
  {
    number: 3,
    title: 'PLACEHOLDER 芒聙聰 Computer Use',
    duration: '~60 min',
    description: 'Competence obligations under Model Rule 1.1 as applied to AI-assisted drafting, research, and document review. What "keeping abreast of changes in the law" now requires.',
  },
  {
    number: 4,
    title: 'Confidentiality & AI Tools',
    duration: '~60 min',
    description: 'Model Rule 1.6 analysis of submitting client data to third-party AI platforms. Covers consent, data retention policies, and firm-level governance requirements.',
  },
  {
    number: 5,
    title: 'Supervision & Billing Ethics',
    duration: '~60 min',
    description: 'Supervisory duties under Rules 5.1 and 5.3 when associates or staff use AI. Addresses billing transparency and the prohibition on charging clients for AI-inflated time.',
  },
  {
    number: 6,
    title: 'AI Policy & Firm Governance',
    duration: '~60 min',
    description: 'Building an AI use policy that satisfies bar guidance, mitigates sanctions risk, and positions the firm for responsible AI adoption. Includes a model policy framework.',
  },
];

const faqs = [
  {
    q: 'Is this course approved for CLE credit?',
    a: 'Accreditation is pending. The course is structured to meet the requirements of most state bar CLE programs covering technology competence and professional responsibility. Contact us for your jurisdiction\'s status.',
  },
  {
    q: 'How many CLE credits does the course provide?',
    a: 'The full six-module course provides approximately 6 hours of CLE credit, with at least 1 hour of ethics credit.',
  },
  {
    q: 'Which Model Rules does the course cover?',
    a: 'The curriculum addresses Rules 1.1 (Competence), 1.6 (Confidentiality), 3.3 (Candor Toward the Tribunal), 5.1 and 5.3 (Supervision), and 1.5 (Fees) 芒聙聰 the rules most frequently implicated in AI-related sanctions.',
  },
  {
    q: 'How is the course licensed?',
    a: 'The course is licensed on a per-attorney basis. Firm-wide and bar association bulk licensing is also available. Contact us for pricing.',
  },
  {
    q: 'Can our bar association use this for member programming?',
    a: 'Yes. The course is available for bar association licensing, including state and local bar CLE programming. Reach out via the contact form to discuss terms.',
  },
  {
    q: 'Is the content based on actual court decisions?',
    a: 'Yes. The case examples throughout the course are drawn from real federal and state court sanctions orders.',
  },
];

const courseSchema = {
  "@context": "https://schema.org",
  "@type": "Course",
  "name": "Generative AI Use Mandatory Training",
  "description": "A 6-hour CLE course covering the professional responsibility rules attorneys must understand when using AI tools 芒聙聰 competence, confidentiality, supervision, candor to the tribunal, and billing ethics under the ABA Model Rules.",
  "url": "https://kameir.com/AI-Ethics-CLE-Course-Sample",
  "provider": {
    "@type": "Organization",
    "name": "Decentralized Publishing LLC",
    "url": "https://kameir.com"
  },
  "educationalLevel": "Professional",
  "numberOfCredits": 6,
  "audience": {
    "@type": "EducationalAudience",
    "educationalRole": "Attorney"
  },
  "teaches": [
    "Model Rule 1.1 Competence and AI tools",
    "Model Rule 1.6 Confidentiality and AI platforms",
    "Model Rule 3.3 Candor and AI hallucinations",
    "Model Rules 5.1 and 5.3 Supervision of AI use",
    "AI billing ethics under Model Rule 1.5"
  ],
  "hasCourseInstance": {
    "@type": "CourseInstance",
    "courseMode": "online",
    "instructor": {
      "@type": "Person",
      "name": "Christian Kameir",
      "url": "https://kameir.com/about"
    }
  }
};
