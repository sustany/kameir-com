Options -Indexes

# ── Clean URL rewrites (strip .html) ─────────────────────────
RewriteEngine On

# Serve existing files and directories as-is
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d

# Strip trailing slash (except root)
RewriteRule ^(.+)/$ /$1 [R=301,L]

# ── 301 redirects for removed pages ──────────────────────────
# Former smart-contracts page (malformed external links land here)
RewriteRule ^smart-contracts(/.*)?$ /writing [R=301,L]

# Former blog posts no longer on site
RewriteRule ^what-is-google(/.*)?$ /writing [R=301,L]
RewriteRule ^money(/.*)?$ /writing [R=301,L]
