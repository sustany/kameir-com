Options -Indexes

# ── Clean URL rewrites (strip .html) ─────────────────────────
RewriteEngine On

# Serve existing files and directories as-is
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d

# Strip trailing slash (except root)
RewriteRule ^(.+)/$ /$1 [R=301,L]

# ── 301 redirects for removed pages ──────────────────────────
# Former smart-contracts page (malformed external links land here)
RewriteRule ^smart-contracts(/.*)?$ /writing [R=301,L]

# Former blog posts no longer on site
RewriteRule ^what-is-google(/.*)?$ /writing [R=301,L]
RewriteRule ^money(/.*)?$ /writing [R=301,L]

# Removed non-US case pages (2026-05-28): any /AI-legal-research/<slug>
# that no longer has a built .html file -> redirect to the database table.
# Catches all 435 retired non-US slugs plus any future typos to dead case pages.
RewriteCond %{DOCUMENT_ROOT}/AI-legal-research/$1.html !-f
RewriteRule ^AI-legal-research/([^/]+)/?$ /AI-legal-research [R=301,L]
