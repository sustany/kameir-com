Options -Indexes

RewriteEngine On

# Strip trailing slash for non-existing paths
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.+)/$ /$1 [R=301,L]

# Extensionless URL -> .html sibling (handles /about, /contact, etc.)
# Uses REQUEST_FILENAME.html test (no $1 in condition - works reliably on LiteSpeed)
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^(.+?)/?$ /$1.html [L]

# Directory request with same-name .html sibling -> serve the .html
# (handles /AI-legal-research where both the dir and AI-legal-research.html exist)
RewriteCond %{REQUEST_FILENAME} -d
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^(.+?)/?$ /$1.html [L]

# ГўВ”ВЂГўВ”ВЂ 301 redirects for removed pages ГўВ”ВЂГўВ”ВЂГўВ”ВЂГўВ”ВЂГўВ”ВЂГўВ”ВЂГўВ”ВЂГўВ”ВЂГўВ”ВЂГўВ”ВЂГўВ”ВЂГўВ”ВЂГўВ”ВЂГўВ”ВЂГўВ”ВЂГўВ”ВЂГўВ”ВЂГўВ”ВЂГўВ”ВЂГўВ”ВЂГўВ”ВЂГўВ”ВЂГўВ”ВЂГўВ”ВЂГўВ”ВЂГўВ”ВЂ
RewriteRule ^smart-contracts(/.*)?$ /writing [R=301,L]
RewriteRule ^what-is-google(/.*)?$ /writing [R=301,L]
RewriteRule ^money(/.*)?$ /writing [R=301,L]

# Removed non-US case pages: /AI-legal-research/<slug> with no built file -> table.
# Both conditions required: file doesn't exist AND its .html sibling doesn't exist.
# Pattern excludes paths containing a dot, so direct .html requests for kept cases
# (e.g. /AI-legal-research/williams.html) are NOT caught here.
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME}.html !-f
RewriteRule ^AI-legal-research/([^./]+?)/?$ /AI-legal-research [R=301,L]
