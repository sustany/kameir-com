# ── Force HTTPS + www → apex ─────────────────────────────────────────
<IfModule mod_rewrite.c>
  RewriteEngine On

  # 1. Redirect HTTP → HTTPS (belt-and-suspenders alongside cPanel)
  RewriteCond %{HTTPS} off
  RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L]

  # 2. Redirect www → apex
  RewriteCond %{HTTP_HOST} ^www\.kameir\.com$ [NC]
  RewriteRule ^ https://kameir.com%{REQUEST_URI} [R=301,L]
</IfModule>

# ── Clean URL handling ────────────────────────────────────────────────
# Astro build:format=file generates about.html, writing.html etc.
# The writing/ directory also exists (holds individual post files), so
# Apache's DirectorySlash would auto-redirect /writing → /writing/ and
# create a loop with any trailing-slash fix. Turn it off globally.
<IfModule mod_rewrite.c>
  RewriteEngine On

  # Disable Apache's auto-redirect of /path to /path/ when a directory exists.
  # Required because writing/ directory and writing.html coexist.
  DirectorySlash Off

  # Strip trailing slashes → 301 to canonical no-slash URL (safe now that
  # DirectorySlash Off prevents Apache from adding them back)
  RewriteCond %{REQUEST_URI} ^/(.+)/$
  RewriteRule ^(.+)/$ /$1 [R=301,L]

  # Redirect old /hallucinations URLs → /AI-legal-research
  RewriteRule ^hallucinations/?$ /AI-legal-research [R=301,L]
  RewriteRule ^hallucinations/(.+)$ /AI-legal-research/$1 [R=301,L]

  # Explicit rewrites for ai-ethics subpages (flat files, no subdirectory on server)
  RewriteRule ^ai-ethics/lead-magnet/?$ /ai-ethics-lead-magnet.html [L]
  RewriteRule ^ai-ethics/book-a-call/?$ /ai-ethics-book-a-call.html [L]

  # Generic clean-URL rule: serve path.html when it exists.
  # Uses DOCUMENT_ROOT check instead of !-d so the writing/ directory
  # conflict doesn't block serving writing.html.
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{DOCUMENT_ROOT}%{REQUEST_URI}.html -f
  RewriteRule ^(.+?)$ $1.html [L]
</IfModule>

# ── Custom 404 ────────────────────────────────────────────────────────
ErrorDocument 404 /404.html

# ── Cache headers ─────────────────────────────────────────────────────
<IfModule mod_expires.c>
  ExpiresActive On

  # Hashed assets (JS/CSS with content hash) — 1 year
  <FilesMatch "\.(js|css|woff2?|ttf|otf)$">
    ExpiresDefault "access plus 1 year"
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>

  # Images — 30 days
  <FilesMatch "\.(jpg|jpeg|png|gif|svg|webp|ico)$">
    ExpiresDefault "access plus 30 days"
    Header set Cache-Control "public, max-age=2592000"
  </FilesMatch>

  # HTML — no cache (always fresh)
 