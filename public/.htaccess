Options -Indexes
ServerSignature Off

# -- Security headers ---------------------------------------------------------
# Note: no <IfModule mod_headers.c> wrapper - LiteSpeed supports Header
# directives natively in .htaccess without requiring mod_headers to be loaded.
Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"
Header always set X-Frame-Options "SAMEORIGIN"
Header always set X-Content-Type-Options "nosniff"
Header always set Referrer-Policy "strict-origin-when-cross-origin"
Header always set Permissions-Policy "camera=(), microphone=(), geolocation=(), payment=()"
Header always set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' https://plausible.io; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; connect-src 'self' https://plausible.io https://formspree.io; font-src 'self'; frame-ancestors 'none'; base-uri 'self'; form-action https://formspree.io;"

RewriteEngine On

# Block dotfiles (/.git, /.env, etc.) - exempt .well-known for AutoSSL
RewriteRule (^|/)\.(?!well-known) - [F,L]

# AI legal research section hidden - redirect all URLs to homepage
RewriteRule ^AI-legal-research(/.*)?$ / [R=301,L]

# Strip trailing slash for non-existing paths
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.+)/$ /$1 [R=301,L]

# Extensionless URL -> .html sibling (handles /about, /contact, etc.)
# Uses REQUEST_FILENAME.html test (no $1 in condition - works reliably on LiteSpeed)
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^(.+?)/?$ /$1.html [L]

# Directory request with same-name .html sibling -> serve the .html
# (handles /AI-legal-research where both the dir and AI-legal-research.html exist)
RewriteCond %{REQUEST_FILENAME} -d
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^(.+?)/?$ /$1.html [L]

# -- 301 redirects for removed pages ------------------------------------------
RewriteRule ^smart-contracts(/.*)?$ /writing [R=301,L]
RewriteRule ^what-is-google(/.*)?$ /writing [R=301,L]
RewriteRule ^money(/.*)?$ /writing [R=301,L]
