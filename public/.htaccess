Options -Indexes

RewriteEngine On

# ── 301 redirects for removed pages (highest priority) ───────
RewriteRule ^smart-contracts(/.*)?$ /writing [R=301,L]
RewriteRule ^what-is-google(/.*)?$ /writing [R=301,L]
RewriteRule ^money(/.*)?$ /writing [R=301,L]

# ── Strip trailing slash (/about/ → /about) ──────────────────
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.+)/$ /$1 [R=301,L]

# ── Serve clean URLs (/about → /about.html) ──────────────────
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^(.+)$ $1.html [L]
